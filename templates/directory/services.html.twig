{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'directoryServicesPageHeading'|trans }}{% endblock %}
{% block page_title %}{{ 'directoryServicesPageHeading'|trans }}{% endblock %}

{% block main %}
    {# Button/spinner/summary/error must all share one data-controller root - page_actions and
       main render in separate DOM regions of layout/app.html.twig, so a controller declared in
       one can never find targets declared in the other. #}
    <div data-controller="directory-sync"
         data-directory-sync-url-value="{{ path('app_directory_services_sync') }}"
         data-directory-sync-token-value="{{ csrf_token('directory_services_sync') }}"
         data-directory-sync-confirm-message-value="{{ 'directoryServicesSyncConfirmMessage'|trans }}"
         data-directory-sync-summary-message-value="{{ 'directoryServicesSyncSummaryMessage'|trans }}"
         class="mb-3">
        <div class="d-flex align-items-center mb-3">
            <button type="button" class="btn btn-outline-secondary me-2" data-directory-sync-target="button" data-action="directory-sync#run">
                {{ 'directoryServicesSyncButtonLabel'|trans }}
            </button>
            <div class="d-none me-2" data-directory-sync-target="spinner">
                <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
            </div>
        </div>
        <div class="d-none alert alert-success mb-3" data-directory-sync-target="summary" role="alert"></div>
        <div class="d-none alert alert-danger mb-3" data-directory-sync-target="error" role="alert">{{ 'directoryServicesSyncErrorMessage'|trans }}</div>
    </div>

    <div class="card"
         data-frankenphp-hot-reload-preserve
         data-controller="datatable"
         data-datatable-url-value="{{ path('app_directory_services_data') }}"
         data-datatable-page-length-value="10"
         data-datatable-columns-value="{{ [
             {data: 'name'},
             {data: 'description'},
             {data: 'creationDate'},
             {data: 'createdByName'},
         ]|json_encode }}"
         data-datatable-language-value="{{ {
             info: 'datatableInfoLabel'|trans,
             infoEmpty: 'datatableInfoEmptyLabel'|trans,
             infoFiltered: 'datatableInfoFilteredLabel'|trans,
             zeroRecords: 'datatableZeroRecordsLabel'|trans,
             processing: 'datatableProcessingLabel'|trans,
             lengthMenu: 'datatableLengthMenuLabel'|trans,
             search: 'datatableSearchLabel'|trans,
             paginate: {
                 next: 'datatablePaginateNextLabel'|trans,
                 previous: 'datatablePaginatePreviousLabel'|trans,
             },
         }|json_encode }}">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-striped" data-datatable-target="table">
                <thead>
                    <tr>
                        <th>{{ 'structureNameColumnLabel'|trans }}</th>
                        <th>{{ 'directoryServiceDescriptionColumnLabel'|trans }}</th>
                        <th>{{ 'structureCreationDateColumnLabel'|trans }}</th>
                        <th>{{ 'structureCreatedByColumnLabel'|trans }}</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
{% endblock %}
