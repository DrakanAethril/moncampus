{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'directorySyncPageHeading'|trans }}{% endblock %}
{% block page_title %}{{ 'directorySyncPageHeading'|trans }}{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <p class="text-secondary">{{ 'directorySyncExplanation'|trans }}</p>
                    <div data-controller="directory-sync"
                         data-directory-sync-url-value="{{ path('app_directory_sync_run') }}"
                         data-directory-sync-token-value="{{ csrf_token('directory_sync') }}"
                         data-directory-sync-confirm-message-value="{{ 'directorySyncConfirmMessage'|trans }}"
                         data-directory-sync-summary-message-value="{{ 'directorySyncSummaryMessage'|trans }}">
                        <button type="button" class="btn btn-primary" data-directory-sync-target="button" data-action="directory-sync#run">
                            {{ 'directorySyncButtonLabel'|trans }}
                        </button>
                        <div class="d-none" data-directory-sync-target="spinner">
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                            {{ 'directorySyncInProgressLabel'|trans }}
                        </div>
                        <div class="d-none alert alert-success mt-3" data-directory-sync-target="summary" role="alert"></div>
                        <div class="d-none alert alert-danger mt-3" data-directory-sync-target="error" role="alert">{{ 'directorySyncErrorMessage'|trans }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
