{% extends 'layout/app.html.twig' %}

{% block title %}{{ thread.subject }}{% endblock %}
{% block page_title %}{{ thread.subject }}{% endblock %}

{% block page_actions %}
    <div class="btn-list">
        {% if recipient.archivedAt is null %}
            <form method="post" action="{{ path('app_messages_archive', {id: thread.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('message_archive') }}">
                <button type="submit" class="btn btn-outline-secondary">{{ 'messageArchiveAction'|trans }}</button>
            </form>
        {% else %}
            <form method="post" action="{{ path('app_messages_unarchive', {id: thread.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('message_unarchive') }}">
                <button type="submit" class="btn btn-outline-secondary">{{ 'messageUnarchiveAction'|trans }}</button>
            </form>
        {% endif %}
        <form method="post" action="{{ path('app_messages_delete', {id: thread.id}) }}" onsubmit="return confirm('{{ 'messageDeleteConfirmMessage'|trans|e('js') }}')">
            <input type="hidden" name="_token" value="{{ csrf_token('message_delete') }}">
            <button type="submit" class="btn btn-outline-danger">{{ 'messageDeleteAction'|trans }}</button>
        </form>
    </div>
{% endblock %}

{% block main %}
    <div class="row row-cards">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">{{ 'messageFromColumnLabel'|trans }}</dt>
                        <dd class="col-sm-9">{{ thread.sender.displayName ?? thread.sender.username }}</dd>
                        <dt class="col-sm-3">{{ 'messageToColumnLabel'|trans }}</dt>
                        <dd class="col-sm-9">{{ audienceLabel }}</dd>
                        {% if readStats is not null %}
                            <dt class="col-sm-3">{{ 'messageReadCountColumnLabel'|trans }}</dt>
                            <dd class="col-sm-9">{{ readStats.read }}/{{ readStats.total }}</dd>
                        {% endif %}
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="cm-thread">
                        {% for message in messages %}
                            <div class="cm-bubble{{ message.author == app.user ? ' cm-bubble--highlight' }}">
                                <div class="cm-bubble__avatar">{{ (message.author.displayName ?? message.author.username)|slice(0, 1)|upper }}</div>
                                <div class="cm-bubble__body">
                                    <div class="cm-bubble__head">
                                        <strong>{{ message.author.displayName ?? message.author.username }}</strong>
                                        <time>{{ message.sentAt|date('d/m/Y H:i') }}</time>
                                    </div>
                                    <div class="cm-bubble__text">{{ message.body|raw }}</div>
                                    {% if message.attachments|length > 0 %}
                                        <div class="mt-2">
                                            {% for attachment in message.attachments %}
                                                <a href="{{ file_url(attachment.storageKey) }}" class="btn btn-outline-secondary btn-sm me-1 mb-1" target="_blank">
                                                    {{ attachment.originalFilename }}
                                                </a>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            {% if canReply %}
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">{{ 'messageReplyHeading'|trans }}</h3>
                    </div>
                    <div class="card-body">
                        {{ form_start(replyForm, {action: path('app_messages_reply', {id: thread.id})}) }}
                            {{ form_errors(replyForm) }}
                            {{ form_row(replyForm.body, {attr: {
                                class: 'd-none',
                                'data-controller': 'hugerte-editor',
                                'data-hugerte-editor-emoji-value': 'true',
                                'data-hugerte-editor-emoji-data-source-value': asset('emoji-picker-data/data.json'),
                                'data-hugerte-editor-emoji-label-value': 'messageEmojiButtonLabel'|trans,
                            }}) }}
                            {{ form_row(replyForm.attachments) }}
                            {{ form_widget(replyForm.submit, {attr: {class: 'btn btn-primary'}}) }}
                            {{ form_rest(replyForm) }}
                        {{ form_end(replyForm) }}
                    </div>
                </div>
            {% elseif thread.sender != app.user %}
                <a href="{{ path('app_messages_new', {to: thread.sender.id, inReplyToThread: thread.id}) }}" class="btn btn-primary">
                    {{ 'messageReplyPrivatelyAction'|trans }}
                </a>
            {% endif %}
        </div>
    </div>
{% endblock %}
