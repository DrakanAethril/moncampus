<h3 class="mb-3">{{ 'homeTeacherSectionHeading'|trans }}</h3>

<div class="row row-cards mb-3">
    <div class="col-md-3">
        <div class="cm-kpi cm-kpi--blue">
            <div class="cm-kpi__label">{{ 'homeTeacherUpcomingSessionsLabel'|trans }}</div>
            <div class="cm-kpi__value">{{ teacher.upcomingSessions|length }}</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="cm-kpi cm-kpi--gold">
            <div class="cm-kpi__label">{{ 'homeTeacherSessionsWithoutLogLabel'|trans }}</div>
            <div class="cm-kpi__value">{{ teacher.sessionsWithoutLogCount }}</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="cm-kpi cm-kpi--green">
            <div class="cm-kpi__label">{{ 'homeTeacherSequenceCountLabel'|trans }}</div>
            <div class="cm-kpi__value">{{ teacher.sequenceCount }}</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="cm-kpi cm-kpi--purple">
            <div class="cm-kpi__label">{{ 'homeTeacherOpenTicketsLabel'|trans }}</div>
            <div class="cm-kpi__value">{{ teacher.openTicketCount }}</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h3 class="card-title">{{ 'homeTeacherUpcomingSessionsTableHeading'|trans }}</h3>
    </div>
    <div class="card-body">
        {% if teacher.upcomingSessions is empty %}
            <p class="text-secondary mb-0">{{ 'datatableZeroRecordsLabel'|trans }}</p>
        {% else %}
            <div class="cm-row-list">
                {% for session in teacher.upcomingSessions %}
                    <div class="cm-row-item{{ cycle(['', ' cm-row-item--gold', ' cm-row-item--green', ' cm-row-item--purple'], loop.index0) }}">
                        <div class="cm-row-item__time">{{ session.day|date('d/m') }} {{ session.startHour|date('H:i') }}</div>
                        <div>
                            <div class="cm-row-item__title">{{ session.displayName }} — {{ session.program.shortName }}</div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h3 class="card-title">{{ 'homeTeacherSessionsWithoutLogTableHeading'|trans }}</h3>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table">
            <thead>
                <tr>
                    <th>{{ 'homeProgramColumnLabel'|trans }}</th>
                    <th>{{ 'lessonSessionDayFieldLabel'|trans }}</th>
                    <th>{{ 'lessonSessionTopicFieldLabel'|trans }}</th>
                    <th class="w-1"></th>
                </tr>
            </thead>
            <tbody>
                {% for session in teacher.sessionsWithoutLog %}
                    <tr>
                        <td>{{ session.program.shortName }}</td>
                        <td>{{ session.day|date('d/m/Y') }}</td>
                        <td>{{ session.displayName }}</td>
                        <td>
                            <a href="{{ path('app_program_timetable_session_log', {id: session.program.id, sessionId: session.id}) }}" class="btn btn-primary btn-sm">
                                {{ 'homeCompleteLogButtonLabel'|trans }}
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-secondary">{{ 'datatableZeroRecordsLabel'|trans }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
