{% set nextSession = student.sessions|first %}

<h3 class="mb-3">
    {{ 'homeStudentSectionHeading'|trans }}
    {% if student.program %}
        <span class="text-secondary">— {{ student.program.shortName }} ({{ student.program.schoolYear.startDate|date('Y') }}-{{ student.program.schoolYear.endDate|date('Y') }})</span>
    {% endif %}
</h3>

{% if not student.program %}
    <div class="card mb-4">
        <div class="card-body text-secondary">{{ 'homeStudentNoActiveProgramMessage'|trans }}</div>
    </div>
{% else %}
    <div class="row row-cards mb-3">
        <div class="col-md-4">
            <div class="cm-kpi cm-kpi--blue">
                <div class="cm-kpi__label">{{ 'homeStudentNextSessionLabel'|trans }}</div>
                <div class="cm-kpi__value">
                    {% if nextSession %}
                        {{ nextSession.day|date('d/m') }} {{ nextSession.startHour|date('H:i') }}
                    {% else %}
                        —
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="cm-kpi cm-kpi--gold">
                <div class="cm-kpi__label">{{ 'homeStudentSessionsThisWeekLabel'|trans }}</div>
                <div class="cm-kpi__value">{{ student.sessions|length }}</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="cm-kpi cm-kpi--green">
                <div class="cm-kpi__label">{{ 'homeStudentOpenTicketsLabel'|trans }}</div>
                <div class="cm-kpi__value">{{ student.openTicketCount }}</div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h3 class="card-title">{{ 'homeStudentSessionsTableHeading'|trans }}</h3>
        </div>
        <div class="card-body">
            {% if student.sessions is empty %}
                <p class="text-secondary mb-0">{{ 'datatableZeroRecordsLabel'|trans }}</p>
            {% else %}
                <div class="cm-row-list">
                    {% for session in student.sessions %}
                        <div class="cm-row-item{{ cycle(['', ' cm-row-item--gold', ' cm-row-item--green', ' cm-row-item--purple'], loop.index0) }}">
                            <div class="cm-row-item__time">{{ session.day|date('d/m') }} {{ session.startHour|date('H:i') }}</div>
                            <div>
                                <div class="cm-row-item__title">{{ session.displayName }}</div>
                                <div class="cm-row-item__meta">{{ session.classRoom ? session.classRoom.name : '—' }}</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
{% endif %}
