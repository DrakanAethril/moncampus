{% extends 'emails/_layout.html.twig' %}

{% block subject %}{{ 'magicLoginEmailSubject'|trans }}{% endblock %}

{% block preheader %}Votre lien de connexion à votre espace campus{% endblock %}

{% block banner %}Connexion{% endblock %}

{% block body %}
    <p style="margin: 0 0 16px;">Bonjour {{ user.firstname ?? user.username }},</p>
    <p style="margin: 0 0 16px;">
        Cliquez sur le bouton ci-dessous pour vous connecter à votre espace campus.
    </p>
    <table role="presentation" cellpadding="0" cellspacing="0" style="margin: 24px 0;">
        <tr>
            <td style="border-radius: 9px; background-color: #1B6BA8;">
                <a href="{{ url('app_login_magic_confirm', {token: token}) }}" style="display: inline-block; padding: 10px 20px; color: #ffffff; text-decoration: none; font-weight: 600;">
                    Me connecter
                </a>
            </td>
        </tr>
    </table>
    <p style="margin: 0 0 16px; color: #8a94a6; font-size: 13px;">
        Ce lien est valable 1 heure et ne peut être utilisé qu'une seule fois. Si vous n'êtes pas
        à l'origine de cette demande, vous pouvez ignorer cet email - personne ne pourra se
        connecter sans y avoir accès.
    </p>
    <p style="margin: 0; color: #8a94a6; font-size: 13px;">
        Cordialement,<br>
        L'équipe pédagogique
    </p>
{% endblock %}
