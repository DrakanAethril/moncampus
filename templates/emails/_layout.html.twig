<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block subject %}{% endblock %}</title>
    </head>
    <body style="margin: 0; padding: 0; background-color: #f4f6f8; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color: #f4f6f8; padding: 32px 16px;">
            <tr>
                <td align="center">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width: 560px; background-color: #ffffff; border-radius: 8px; overflow: hidden;">
                        <tr>
                            <td align="center" style="background-color: #0f6cbd; padding: 24px;">
                                {# Icon-only mark (assets/images/apple-touch-icon.png) - no text alongside it,
                                   since the From display name "Institution Beaupeyrat" already says who this
                                   is from. #}
                                <img src="{{ email.image('emails/images/logo.png') }}" width="56" height="56" alt="Institution Beaupeyrat">
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 32px 32px 16px; color: #182433; font-size: 15px; line-height: 1.6;">
                                {% block body %}{% endblock %}
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 16px 32px 32px; color: #8a94a6; font-size: 12px; line-height: 1.5; border-top: 1px solid #eef1f4;">
                                Institution Beaupeyrat
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </body>
</html>
