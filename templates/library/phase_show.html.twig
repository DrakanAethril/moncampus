{% extends 'layout/app.html.twig' %}

{% block title %}{{ phaseTemplate.nom }} - {{ seanceTemplate.titre }}{% endblock %}
{% block page_title %}{{ phaseTemplate.nom }}{% endblock %}

{% block page_actions %}
    {% if canEdit %}
        <a href="{{ path('app_library_phases_edit', {sequenceId: sequenceTemplate.id, seanceId: seanceTemplate.id, id: phaseTemplate.id}) }}" class="btn btn-outline-secondary">{{ 'editActionLabel'|trans }}</a>
    {% endif %}
{% endblock %}

{% block main %}
    <div class="mb-3">
        <a href="{{ path('app_library_seances_show', {sequenceId: sequenceTemplate.id, id: seanceTemplate.id}) }}" class="btn btn-link ps-0">{{ 'backToSeanceAction'|trans }}</a>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-3">{{ 'seancePhaseTemplateDureeFieldLabel'|trans }}</dt>
                <dd class="col-9">{{ phaseTemplate.duree ?? '—' }}</dd>
                {% if phaseTemplate.contenu %}
                    <dt class="col-3">{{ 'seancePhaseTemplateContenuFieldLabel'|trans }}</dt>
                    <dd class="col-9" style="white-space: pre-wrap;">{{ phaseTemplate.contenu }}</dd>
                {% endif %}
                {% if phaseTemplate.objectifs %}
                    <dt class="col-3">{{ 'seancePhaseTemplateObjectifsFieldLabel'|trans }}</dt>
                    <dd class="col-9" style="white-space: pre-wrap;">{{ phaseTemplate.objectifs }}</dd>
                {% endif %}
                {% if phaseTemplate.enseignant %}
                    <dt class="col-3">{{ 'seancePhaseTemplateEnseignantFieldLabel'|trans }}</dt>
                    <dd class="col-9" style="white-space: pre-wrap;">{{ phaseTemplate.enseignant }}</dd>
                {% endif %}
                {% if phaseTemplate.etudiant %}
                    <dt class="col-3">{{ 'seancePhaseTemplateEtudiantFieldLabel'|trans }}</dt>
                    <dd class="col-9" style="white-space: pre-wrap;">{{ phaseTemplate.etudiant }}</dd>
                {% endif %}
                {% if phaseTemplate.moyensSupports %}
                    <dt class="col-3">{{ 'seancePhaseTemplateMoyensSupportsFieldLabel'|trans }}</dt>
                    <dd class="col-9" style="white-space: pre-wrap;">{{ phaseTemplate.moyensSupports }}</dd>
                {% endif %}
                {% if phaseTemplate.difficultes %}
                    <dt class="col-3">{{ 'seancePhaseTemplateDifficultesFieldLabel'|trans }}</dt>
                    <dd class="col-9" style="white-space: pre-wrap;">{{ phaseTemplate.difficultes }}</dd>
                {% endif %}
            </dl>
        </div>
    </div>

    {% include 'library/_resources.html.twig' with {
        resources: phaseTemplate.libraryResources,
        canEdit: canEdit,
        resourceForm: resourceForm,
        tagOptions: tagOptions,
        addRouteName: 'app_library_phases_resources_new',
        addRouteParams: {sequenceId: sequenceTemplate.id, seanceId: seanceTemplate.id, id: phaseTemplate.id},
        deleteRouteName: 'app_library_phases_resources_delete',
        deleteRouteParams: {sequenceId: sequenceTemplate.id, seanceId: seanceTemplate.id, id: phaseTemplate.id},
    } only %}

    {% if canEdit %}
        <form method="post" action="{{ path('app_library_phases_remove', {sequenceId: sequenceTemplate.id, seanceId: seanceTemplate.id, id: phaseTemplate.id}) }}" class="mt-3" onsubmit="return confirm('{{ 'removeSeancePhaseTemplateConfirmMessage'|trans|e('js') }}')">
            <input type="hidden" name="_token" value="{{ csrf_token('library_phases_remove') }}">
            <button type="submit" class="btn btn-ghost-danger">{{ 'removeActionLabel'|trans }}</button>
        </form>
    {% endif %}
{% endblock %}
