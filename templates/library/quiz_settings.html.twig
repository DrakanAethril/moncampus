{% extends 'layout/app.html.twig' %}

{% block title %}{{ quizTemplate.name }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: 'quizLibraryPageHeading'|trans, url: path('app_library_quiz')},
        {label: quizTemplate.name, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ quizTemplate.name }}{% endblock %}

{% block main %}
    {% include '_tabs.html.twig' with {
        tabs: [
            {url: path('app_library_quiz_questions', {id: quizTemplate.id}), label: 'quizTabQuestionsLabel'|trans, active: false},
            {url: path('app_library_quiz_settings', {id: quizTemplate.id}), label: 'quizTabSettingsLabel'|trans, active: true},
        ],
    } %}
    <div class="card cm-card--tabbed">
        <div class="card-body">
            {{ form_start(form) }}
            {{ form_errors(form) }}
            <div class="row g-4 align-items-start">
                <div class="col-12 col-lg-6 d-flex flex-column gap-3">
                    <div class="cm-subhead">
                        <div class="cm-subhead__title">{{ 'quizSettingsIdentityTitle'|trans }}</div>
                        <div class="cm-subhead__hint">{{ 'quizSettingsIdentityHint'|trans }}</div>
                    </div>
                    <div style="max-width: 420px;">
                        {{ form_row(form.name) }}
                    </div>
                    <div style="max-width: 280px;">
                        {{ form_row(form.subject) }}
                    </div>
                    {{ form_row(form.description) }}
                </div>
                <div class="col-12 col-lg-6 d-flex flex-column gap-3">
                    <div class="cm-subhead">
                        <div class="cm-subhead__title">{{ 'quizSettingsDefaultsTitle'|trans }}</div>
                        <div class="cm-subhead__hint">{{ 'quizSettingsDefaultsHint'|trans }}</div>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">{{ form_row(form.defaultQuestionCount) }}</div>
                        <div class="col-6">{{ form_row(form.defaultSecondsPerQuestion) }}</div>
                    </div>
                    <div class="d-flex flex-column gap-2">
                        {{ form_row(form.defaultSameQuestionsForAll, {row_attr: {class: 'form-switch'}}) }}
                        {{ form_row(form.defaultQuestionOrderPerStudent, {row_attr: {class: 'form-switch'}}) }}
                        {{ form_row(form.defaultAnswerOrderPerStudent, {row_attr: {class: 'form-switch'}}) }}
                    </div>
                    <div class="cm-note">
                        <span class="cm-note__icon">i</span>
                        <div>{{ 'quizSettingsDefaultsNoteText'|trans }}</div>
                    </div>
                </div>
            </div>
            <div class="cm-actionbar">
                {% include '_last_modified_meta.html.twig' with {entity: quizTemplate} %}
                <div class="cm-actionbar__buttons">
                    <a href="{{ path('app_library_quiz') }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit) }}
                </div>
            </div>
            {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
