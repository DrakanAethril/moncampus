{% extends 'layout/app.html.twig' %}

{% block title %}{{ sequenceTemplate.titre }}{% endblock %}
{% block page_title %}{{ sequenceTemplate.titre }}{% endblock %}

{% block page_actions %}
    {% if canEdit %}
        <a href="{{ path('app_library_sequences_edit', {id: sequenceTemplate.id}) }}" class="btn btn-outline-secondary">{{ 'editActionLabel'|trans }}</a>
        <a href="{{ path('app_library_sequences_instantiate', {id: sequenceTemplate.id}) }}" class="btn btn-primary ms-2">{{ 'sequenceInstantiateAction'|trans }}</a>
    {% endif %}
{% endblock %}

{% block main %}
    <div class="mb-3">
        <a href="{{ path('app_library_sequences') }}" class="btn btn-link ps-0">{{ 'backToLibraryAction'|trans }}</a>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-3">{{ 'sequenceTemplateNiveauFieldLabel'|trans }}</dt>
                <dd class="col-9">{{ sequenceTemplate.niveau ? sequenceTemplate.niveau.label : '—' }}</dd>
                <dt class="col-3">{{ 'sequenceTemplateOptionFieldLabel'|trans }}</dt>
                <dd class="col-9">{{ sequenceTemplate.option ? sequenceTemplate.option.label : '—' }}</dd>
                {% if sequenceTemplate.blocs is not empty %}
                    <dt class="col-3">{{ 'sequenceTemplateBlocsFieldLabel'|trans }}</dt>
                    <dd class="col-9">
                        {% for bloc in sequenceTemplate.blocs %}<span class="badge bg-blue-lt me-1">{{ bloc.label }}</span>{% endfor %}
                    </dd>
                {% endif %}
                {% if sequenceTemplate.objectifs %}
                    <dt class="col-3">{{ 'sequenceTemplateObjectifsFieldLabel'|trans }}</dt>
                    <dd class="col-9" style="white-space: pre-wrap;">{{ sequenceTemplate.objectifs }}</dd>
                {% endif %}
            </dl>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">{{ 'librarySeancesSectionTitle'|trans }}</h3>
            {% if canEdit %}
                <a href="{{ path('app_library_seances_new', {sequenceId: sequenceTemplate.id}) }}" class="btn btn-sm btn-primary">{{ 'seanceTemplateNewButtonLabel'|trans }}</a>
            {% endif %}
        </div>
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                    <tr>
                        <th class="w-1">{{ 'seanceTemplateOrdreFieldLabel'|trans }}</th>
                        <th>{{ 'seanceTemplateTitreFieldLabel'|trans }}</th>
                        <th>{{ 'seanceTemplateDureeFieldLabel'|trans }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for seanceTemplate in sequenceTemplate.seanceTemplates %}
                        <tr>
                            <td>{{ seanceTemplate.ordre }}</td>
                            <td>
                                <a href="{{ path('app_library_seances_show', {sequenceId: sequenceTemplate.id, id: seanceTemplate.id}) }}">{{ seanceTemplate.titre }}</a>
                                {% if seanceTemplate.isOptional %}<span class="badge bg-secondary-lt ms-1">{{ 'seanceTemplateIsOptionalBadge'|trans }}</span>{% endif %}
                            </td>
                            <td>{{ seanceTemplate.duree ?? '—' }}</td>
                            <td class="text-end">
                                {% if canEdit %}
                                    <a href="{{ path('app_library_seances_edit', {sequenceId: sequenceTemplate.id, id: seanceTemplate.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'editActionLabel'|trans }}</a>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-secondary">{{ 'librarySeancesEmptyMessage'|trans }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% include 'library/_resources.html.twig' with {
        resources: sequenceTemplate.libraryResources,
        canEdit: canEdit,
        resourceForm: resourceForm,
        tagOptions: tagOptions,
        addRouteName: 'app_library_sequences_resources_new',
        addRouteParams: {id: sequenceTemplate.id},
        deleteRouteName: 'app_library_sequences_resources_delete',
        deleteRouteParams: {id: sequenceTemplate.id},
    } only %}

    {% if canEdit %}
        <form method="post" action="{{ path('app_library_sequences_remove', {id: sequenceTemplate.id}) }}" class="mt-3" onsubmit="return confirm('{{ 'removeSequenceTemplateConfirmMessage'|trans|e('js') }}')">
            <input type="hidden" name="_token" value="{{ csrf_token('library_sequences_remove') }}">
            <button type="submit" class="btn btn-ghost-danger">{{ 'removeActionLabel'|trans }}</button>
        </form>
    {% endif %}
{% endblock %}
