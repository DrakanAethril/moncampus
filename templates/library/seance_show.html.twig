{% extends 'layout/app.html.twig' %}

{% block title %}{{ seanceTemplate.titre }} - {{ sequenceTemplate.titre }}{% endblock %}
{% block page_title %}{{ seanceTemplate.titre }}{% endblock %}

{% block page_actions %}
    {% if canEdit %}
        <a href="{{ path('app_library_seances_edit', {sequenceId: sequenceTemplate.id, id: seanceTemplate.id}) }}" class="btn btn-outline-secondary">{{ 'editActionLabel'|trans }}</a>
        <a href="{{ path('app_library_seances_instantiate', {sequenceId: sequenceTemplate.id, id: seanceTemplate.id}) }}" class="btn btn-primary ms-2">{{ 'seanceInstantiateStandaloneAction'|trans }}</a>
    {% endif %}
{% endblock %}

{% block main %}
    <div class="mb-3">
        <a href="{{ path('app_library_sequences_show', {id: sequenceTemplate.id}) }}" class="btn btn-link ps-0">{{ 'backToSequenceAction'|trans }}</a>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-3">{{ 'seanceTemplateDureeFieldLabel'|trans }}</dt>
                <dd class="col-9">{{ seanceTemplate.duree ?? '—' }}</dd>
                {% if seanceTemplate.objectifs %}
                    <dt class="col-3">{{ 'seanceTemplateObjectifsFieldLabel'|trans }}</dt>
                    <dd class="col-9" style="white-space: pre-wrap;">{{ seanceTemplate.objectifs }}</dd>
                {% endif %}
                {% if seanceTemplate.avantDescription %}
                    <dt class="col-3">{{ 'seanceTemplateAvantDescriptionFieldLabel'|trans }}</dt>
                    <dd class="col-9" style="white-space: pre-wrap;">{{ seanceTemplate.avantDescription }}</dd>
                {% endif %}
                {% if seanceTemplate.apresDescription %}
                    <dt class="col-3">{{ 'seanceTemplateApresDescriptionFieldLabel'|trans }}</dt>
                    <dd class="col-9" style="white-space: pre-wrap;">{{ seanceTemplate.apresDescription }}</dd>
                {% endif %}
            </dl>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">{{ 'libraryPhasesSectionTitle'|trans }}</h3>
            {% if canEdit %}
                <a href="{{ path('app_library_phases_new', {sequenceId: sequenceTemplate.id, seanceId: seanceTemplate.id}) }}" class="btn btn-sm btn-primary">{{ 'seancePhaseTemplateNewButtonLabel'|trans }}</a>
            {% endif %}
        </div>
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                    <tr>
                        <th class="w-1">{{ 'seancePhaseTemplateOrdreFieldLabel'|trans }}</th>
                        <th>{{ 'seancePhaseTemplateNomFieldLabel'|trans }}</th>
                        <th>{{ 'seancePhaseTemplateDureeFieldLabel'|trans }}</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for phase in seanceTemplate.seancePhaseTemplates %}
                        <tr>
                            <td>{{ phase.ordre }}</td>
                            <td>{{ phase.nom }}</td>
                            <td>{{ phase.duree ?? '—' }}</td>
                            <td class="text-end">
                                {% if canEdit %}
                                    <a href="{{ path('app_library_phases_edit', {sequenceId: sequenceTemplate.id, seanceId: seanceTemplate.id, id: phase.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'editActionLabel'|trans }}</a>
                                    <form method="post" action="{{ path('app_library_phases_remove', {sequenceId: sequenceTemplate.id, seanceId: seanceTemplate.id, id: phase.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'removeSeancePhaseTemplateConfirmMessage'|trans|e('js') }}')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('library_phases_remove') }}">
                                        <button type="submit" class="btn btn-sm btn-ghost-danger">{{ 'removeActionLabel'|trans }}</button>
                                    </form>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-secondary">{{ 'libraryPhasesEmptyMessage'|trans }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if canEdit %}
        <form method="post" action="{{ path('app_library_seances_remove', {sequenceId: sequenceTemplate.id, id: seanceTemplate.id}) }}" class="mt-3" onsubmit="return confirm('{{ 'removeSeanceTemplateConfirmMessage'|trans|e('js') }}')">
            <input type="hidden" name="_token" value="{{ csrf_token('library_seances_remove') }}">
            <button type="submit" class="btn btn-ghost-danger">{{ 'removeActionLabel'|trans }}</button>
        </form>
    {% endif %}
{% endblock %}
