{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'seanceInstantiateStandaloneAction'|trans }} - {{ seanceTemplate.titre }}{% endblock %}
{% block page_title %}{{ 'seanceInstantiateStandaloneAction'|trans }} - {{ seanceTemplate.titre }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            <p class="text-secondary">{{ 'seanceInstantiateStandaloneHelpText'|trans }}</p>
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.program) }}</div>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_library_seances_show', {sequenceId: sequenceTemplate.id, id: seanceTemplate.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
