{% extends 'layout/app.html.twig' %}

{% block title %}{{ ticket.subject }}{% endblock %}
{% block page_title %}{{ ticket.subject }}{% endblock %}

{% block page_actions %}
    <a href="{{ isHandler ? path('app_tickets_queue') : path('app_tickets') }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
{% endblock %}

{% block main %}
    <div class="mb-3 d-flex gap-2">
        <span class="badge {{ statusClass }}">{{ statusLabel }}</span>
        <span class="badge {{ priorityClass }}">{{ priorityLabel }}</span>
    </div>

    <div class="row row-cards">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body">
                    <div class="cm-thread">
                        <div class="cm-bubble">
                            <div class="cm-bubble__avatar">
                                {% if ticket.anonymous %}
                                    {{ ticket.reporterName|slice(0, 1)|upper }}
                                {% else %}
                                    {{ (ticket.reporter.displayName ?? ticket.reporter.username)|slice(0, 1)|upper }}
                                {% endif %}
                            </div>
                            <div class="cm-bubble__body">
                                <div class="cm-bubble__head">
                                    <strong>
                                        {% if ticket.anonymous %}
                                            {{ ticket.reporterName }}
                                        {% else %}
                                            {{ ticket.reporter.displayName ?? ticket.reporter.username }}
                                        {% endif %}
                                    </strong>
                                    <time>{{ ticket.creationDate|date('d/m/Y H:i') }}</time>
                                </div>
                                <p class="cm-bubble__text mb-0">{{ ticket.description|nl2br }}</p>
                            </div>
                        </div>

                        {% for comment in comments %}
                            <div class="cm-bubble{{ comment.internal ? ' cm-bubble--internal' }}">
                                <div class="cm-bubble__avatar">{{ (comment.author.displayName ?? comment.author.username)|slice(0, 1)|upper }}</div>
                                <div class="cm-bubble__body">
                                    <div class="cm-bubble__head">
                                        <strong>{{ comment.author.displayName ?? comment.author.username }}</strong>
                                        {% if comment.internal %}<span class="badge bg-orange-lt">{{ 'ticketVisibilityInternalLabel'|trans }}</span>{% endif %}
                                        <time>{{ comment.creationDate|date('d/m/Y H:i') }}</time>
                                    </div>
                                    <p class="cm-bubble__text mb-0">{{ comment.body|nl2br }}</p>
                                </div>
                            </div>
                        {% else %}
                            <p class="text-secondary mb-0">{{ 'ticketNoCommentsLabel'|trans }}</p>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-body">
                    {{ form_start(commentForm, {action: path('app_tickets_comment', {id: ticket.id})}) }}
                        {{ form_errors(commentForm) }}
                        {{ form_row(commentForm.body) }}
                        {% if commentForm.visibility is defined %}
                            {{ form_row(commentForm.visibility) }}
                        {% endif %}
                        {{ form_widget(commentForm.submit) }}
                        {{ form_rest(commentForm) }}
                    {{ form_end(commentForm) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="cm-props mb-3">
                <div class="cm-props__title">{{ 'ticketPropertiesPanelHeading'|trans }}</div>
                <div class="cm-props__field">
                    <label>{{ 'ticketCategoryColumnLabel'|trans }}</label>
                    <div>{{ ticket.category.name }}</div>
                </div>
                <div class="cm-props__field">
                    <label>{{ 'ticketLocationColumnLabel'|trans }}</label>
                    <div>{{ ticket.room.name ?? ticket.otherLocation ?? '—' }}</div>
                </div>
                <div class="cm-props__field">
                    <label>{{ 'ticketReporterColumnLabel'|trans }}</label>
                    <div>
                        {% if ticket.anonymous %}
                            {{ ticket.reporterName }} <span class="text-secondary">({{ ticket.reporterContact }})</span>
                            <span class="badge bg-orange-lt ms-1">{{ 'ticketAnonymousReporterLabel'|trans }}</span>
                        {% else %}
                            {{ ticket.reporter.displayName ?? ticket.reporter.username }}
                        {% endif %}
                    </div>
                </div>
                <div class="cm-props__field">
                    <label>{{ 'ticketAssigneeColumnLabel'|trans }}</label>
                    <div>{{ ticket.assignee ? (ticket.assignee.displayName ?? ticket.assignee.username) : 'ticketUnassignedLabel'|trans }}</div>
                </div>
                <div class="cm-props__field">
                    <label>{{ 'ticketCreatedAtColumnLabel'|trans }}</label>
                    <div>{{ ticket.creationDate|date('d/m/Y H:i') }}</div>
                </div>
            </div>

            {% if isHandler and manageForm is not null %}
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">{{ 'ticketManagePanelHeading'|trans }}</h3>
                    </div>
                    <div class="card-body">
                        {{ form_start(manageForm, {action: path('app_tickets_manage', {id: ticket.id})}) }}
                            {{ form_errors(manageForm) }}
                            {{ form_row(manageForm.status) }}
                            {{ form_row(manageForm.priority) }}
                            {{ form_row(manageForm.assignee) }}
                            {{ form_widget(manageForm.submit) }}
                            {{ form_rest(manageForm) }}
                        {{ form_end(manageForm) }}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
