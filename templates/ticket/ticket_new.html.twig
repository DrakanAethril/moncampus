{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'newTicketPageHeading'|trans }}{% endblock %}
{% block page_title %}{{ 'newTicketPageHeading'|trans }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-12">{{ form_row(form.subject) }}</div>
                    <div class="col-md-6">{{ form_row(form.category) }}</div>
                    <div class="col-md-6">{{ form_row(form.room) }}</div>
                    <div class="col-md-6">{{ form_row(form.otherLocation) }}</div>
                    <div class="col-12">{{ form_row(form.description) }}</div>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_tickets') }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
