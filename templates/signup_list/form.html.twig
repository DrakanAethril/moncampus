{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'signupListEditPageHeading' : 'signupListNewPageHeading')|trans }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'signupListEditPageHeading' : 'signupListNewPageHeading')|trans }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}

                <div class="row">
                    <div class="col-12">{{ form_row(form.title) }}</div>
                    <div class="col-12">{{ form_row(form.description, {attr: {
                        class: 'd-none',
                        'data-controller': 'hugerte-editor',
                    }}) }}</div>
                </div>

                {% if isEdit and signupList.attachments|length > 0 %}
                    <div class="mb-3">
                        <label class="form-label">{{ 'messageAttachmentsFieldLabel'|trans }}</label>
                        <div class="d-flex flex-wrap gap-1">
                            {% for attachment in signupList.attachments %}
                                <div class="btn-group">
                                    <a href="{{ file_url(attachment.storageKey) }}" class="btn btn-outline-secondary btn-sm" target="_blank">{{ attachment.originalFilename }}</a>
                                    <form method="post" action="{{ path('app_signup_lists_attachments_remove', {id: signupList.id, attachmentId: attachment.id}) }}" onsubmit="return confirm('{{ 'removeConfirmMessage'|trans|e('js') }}')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('signup_list_remove_attachment') }}">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">&times;</button>
                                    </form>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
                {{ form_row(form.attachments) }}

                <div class="row">
                    <div class="col-md-6">{{ form_row(form.registrationDeadline) }}</div>
                    <div class="col-md-6">{{ form_row(form.publicRoster) }}</div>
                </div>

                <div data-controller="message-audience" data-action="change->message-audience#toggle">
                    {{ form_row(form.audienceType) }}
                    <div data-message-audience-target="programField">
                        {{ form_row(form.programs) }}
                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.includeStudents) }}</div>
                            <div class="col-md-6">{{ form_row(form.includeTeachers) }}</div>
                        </div>
                    </div>
                    <div class="mb-3" data-message-audience-target="recipientsField">
                        <label class="form-label" for="recipients">{{ 'messageRecipientsFieldLabel'|trans }}</label>
                        <select id="recipients" name="recipients[]" multiple class="form-select"
                                data-controller="tom-select"
                                data-tom-select-url-value="{{ path('app_signup_lists_recipients_search') }}"
                                data-tom-select-placeholder-value="{{ 'messageRecipientsSearchPlaceholder'|trans }}">
                            {% for recipient in signupList.manualRecipients %}
                                <option value="{{ recipient.id }}" selected>{{ recipient.displayName ?? recipient.username }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a href="{{ path(isEdit ? 'app_signup_lists_show' : 'app_signup_lists', isEdit ? {id: signupList.id} : {}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
