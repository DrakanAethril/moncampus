{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'editUserPageHeading'|trans }} - {{ editedUser.displayName ?? editedUser.username }}{% endblock %}
{% block page_title %}{{ 'editUserPageHeading'|trans }} - {{ editedUser.displayName ?? editedUser.username }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-2">{{ 'userUsernameColumnLabel'|trans }}</dt>
                <dd class="col-4">{{ editedUser.username }}</dd>
                <dt class="col-2">{{ 'userEmailColumnLabel'|trans }}</dt>
                <dd class="col-4">{{ editedUser.email ?? '—' }}</dd>
            </dl>
            <p class="text-secondary">{{ 'userProfileLdapOwnedNotice'|trans }}</p>
            <hr>
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-md-6">
                        {{ form_row(form.contactEmail) }}
                        {% if editedUser.contactEmail is not null %}
                            <p class="mb-3">
                                {% if editedUser.contactEmailVerified %}
                                    <span class="badge bg-green-lt">{{ 'contactEmailVerifiedBadgeLabel'|trans }}</span>
                                {% else %}
                                    <span class="badge bg-orange-lt">{{ 'contactEmailPendingBadgeLabel'|trans }}</span>
                                {% endif %}
                            </p>
                        {% endif %}
                    </div>
                    <div class="col-md-6">{{ form_row(form.phoneNumber) }}</div>
                    <div class="col-12">{{ form_row(form.manualGroups) }}</div>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_users') }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
