{% extends 'layout/external.html.twig' %}

{% block title %}{{ 'internshipEvaluatePageHeading'|trans }} — {{ tutorLink.student.displayName ?? tutorLink.student.username }}{% endblock %}
{% block page_title %}{{ 'internshipEvaluatePageHeading'|trans }} — {{ tutorLink.student.displayName ?? tutorLink.student.username }} ({{ period.name }}){% endblock %}

{% block main %}
    {{ form_start(form) }}
        {{ form_errors(form) }}

        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title mb-0">{{ 'internshipEvaluationBehaviorSectionHeading'|trans }}</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter card-table">
                    <thead>
                        <tr>
                            <th>{{ 'internshipBehaviorLabelColumnLabel'|trans }}</th>
                            <th>{{ 'internshipEvaluationLevelColumnLabel'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for behaviorEntry in form.behaviorEvaluations %}
                            <tr>
                                <td>{{ behaviorEntry.vars.data.behaviorCriteria.label }}</td>
                                <td>{{ form_widget(behaviorEntry.behaviorLevel) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title mb-0">{{ 'internshipEvaluationSkillsSectionHeading'|trans }}</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter card-table">
                    <thead>
                        <tr>
                            <th>{{ 'internshipSkillCriterionLabelColumnLabel'|trans }}</th>
                            <th>{{ 'internshipEvaluationLevelColumnLabel'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set currentGroupId = null %}
                        {% for skillEntry in form.skillEvaluations %}
                            {% set skillGroup = skillEntry.vars.data.skillCriterion.skillGroup %}
                            {% if skillGroup.id != currentGroupId %}
                                <tr class="table-active">
                                    <th colspan="2">{{ skillGroup.label }}</th>
                                </tr>
                                {% set currentGroupId = skillGroup.id %}
                            {% endif %}
                            <tr>
                                <td>{{ skillEntry.vars.data.skillCriterion.label }}</td>
                                <td>{{ form_widget(skillEntry.skillLevel) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                {{ form_row(form.strengthsText) }}
                {{ form_row(form.weaknessesText) }}
                {{ form_row(form.goalsText) }}
                {{ form_row(form.remarksText) }}
            </div>
        </div>

        <div class="d-flex justify-content-between">
            <a href="{{ path('app_internship_tutor_home') }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
            {{ form_widget(form.submit) }}
        </div>
        {{ form_rest(form) }}
    {{ form_end(form) }}
{% endblock %}
