{% extends 'base.html.twig' %}

{% block title %}{{ 'authPageTitle'|trans }}{% endblock %}

{% block body %}
    <div class="cm-login">
        <div class="cm-login__brand">
            <div style="position:absolute;right:-120px;bottom:-120px;width:380px;height:380px;border-radius:50%;border:60px solid rgba(255,255,255,.06)"></div>
            <div style="position:absolute;right:60px;top:-80px;width:220px;height:220px;border-radius:50%;border:40px solid rgba(201,160,78,.15)"></div>
            <div class="cm-login__logo-center">
                <img src="{{ asset('images/beaupeyrat-logo.png') }}" alt="Institution Beaupeyrat" style="max-width: 240px; width: 100%; height: auto;">
            </div>
        </div>
        <div class="cm-login__form-side position-relative">
            <div class="position-absolute top-0 end-0 m-3" data-controller="theme" data-theme-authenticated-value="false">
                <button type="button" class="cm-theme-toggle" title="{{ 'toggleThemeLabel'|trans }}" data-action="theme#toggle">
                    <span class="cm-theme-toggle__knob"></span>
                </button>
            </div>
            <div class="cm-login__form">
                <div>
                    <h2 class="h2" style="margin: 0;">{{ 'authWelcomeHeading'|trans }}</h2>
                </div>

                {% if error %}
                    <div class="alert alert-danger" role="alert">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" autocomplete="off" novalidate class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label" for="username">{{ 'usernameFieldLabel'|trans }}</label>
                        <input type="text" id="username" name="_username" class="form-control" value="{{ last_username }}" placeholder="{{ 'usernameFieldPlaceholder'|trans }}" autocomplete="username" autofocus>
                    </div>
                    <div data-controller="password-visibility">
                        <label class="form-label" for="password">{{ 'passwordFieldLabel'|trans }}</label>
                        <div class="input-group input-group-flat">
                            <input type="password" id="password" name="_password" class="form-control" placeholder="{{ 'passwordFieldPlaceholder'|trans }}" autocomplete="current-password" data-password-visibility-target="input">
                            <span class="input-group-text">
                                <a href="#" class="link-secondary" title="{{ 'togglePasswordVisibilityHint'|trans }}" data-action="password-visibility#toggle">
                                    <svg data-password-visibility-target="shownIcon" xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" /><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6" /></svg>
                                    <svg data-password-visibility-target="hiddenIcon" class="icon d-none" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10.585 10.587a2 2 0 0 0 2.829 2.828" /><path d="M16.681 16.673a8.717 8.717 0 0 1 -4.681 1.327c-3.6 0 -6.6 -2 -9 -6c1.272 -2.12 2.712 -3.678 4.32 -4.674m2.86 -1.146a9.055 9.055 0 0 1 1.82 -.18c3.6 0 6.6 2 9 6c-.666 1.11 -1.379 2.067 -2.138 2.87" /><path d="M3 3l18 18" /></svg>
                                </a>
                            </span>
                        </div>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="btn btn-primary w-100">{{ 'submitLoginAction'|trans }}</button>
                </form>
                <div class="text-center text-secondary">
                    <a href="{{ path('app_login_help') }}">{{ 'lostAccountAccessLinkLabel'|trans }}</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
