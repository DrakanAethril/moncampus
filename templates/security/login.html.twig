{% extends 'base.html.twig' %}

{% block title %}{{ 'authPageTitle'|trans }}{% endblock %}

{% block body %}
    <div class="page page-center">
        <div class="position-fixed top-0 end-0 m-3" data-controller="theme" data-theme-authenticated-value="false">
            <a href="#" class="nav-link px-0 hide-theme-dark" title="{{ 'enableDarkModeLabel'|trans }}" data-bs-toggle="tooltip" data-action="theme#setDark">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z" /></svg>
            </a>
            <a href="#" class="nav-link px-0 hide-theme-light" title="{{ 'enableLightModeLabel'|trans }}" data-bs-toggle="tooltip" data-action="theme#setLight">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" /><path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7" /></svg>
            </a>
        </div>
        <div class="container container-normal py-4">
            <div class="row align-items-center g-4 justify-content-center">
                <div class="col-lg-6">
                    <div class="container-tight">
                        <div class="text-center mb-4">
                            <img src="{{ asset('images/beaupeyrat-logo.png') }}" alt="Institution Beaupeyrat" height="90">
                        </div>
                        <form method="post" class="card card-md" autocomplete="off" novalidate>
                            <div class="card-body">
                                <h2 class="h2 text-center mb-4">{{ 'authWelcomeHeading'|trans }}</h2>

                                {% if error %}
                                    <div class="alert alert-danger" role="alert">
                                        {{ error.messageKey|trans(error.messageData, 'security') }}
                                    </div>
                                {% endif %}

                                <div class="mb-3">
                                    <label class="form-label" for="username">{{ 'usernameFieldLabel'|trans }}</label>
                                    <input type="text" id="username" name="_username" class="form-control" value="{{ last_username }}" placeholder="{{ 'usernameFieldPlaceholder'|trans }}" autocomplete="username" autofocus>
                                </div>
                                <div class="mb-2" data-controller="password-visibility">
                                    <label class="form-label" for="password">{{ 'passwordFieldLabel'|trans }}</label>
                                    <div class="input-group input-group-flat">
                                        <input type="password" id="password" name="_password" class="form-control" placeholder="{{ 'passwordFieldPlaceholder'|trans }}" autocomplete="current-password" data-password-visibility-target="input">
                                        <span class="input-group-text">
                                            <a href="#" class="link-secondary" title="{{ 'togglePasswordVisibilityHint'|trans }}" data-action="password-visibility#toggle">
                                                <svg data-password-visibility-target="shownIcon" xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" /><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6" /></svg>
                                                <svg data-password-visibility-target="hiddenIcon" class="icon d-none" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10.585 10.587a2 2 0 0 0 2.829 2.828" /><path d="M16.681 16.673a8.717 8.717 0 0 1 -4.681 1.327c-3.6 0 -6.6 -2 -9 -6c1.272 -2.12 2.712 -3.678 4.32 -4.674m2.86 -1.146a9.055 9.055 0 0 1 1.82 -.18c3.6 0 6.6 2 9 6c-.666 1.11 -1.379 2.067 -2.138 2.87" /><path d="M3 3l18 18" /></svg>
                                            </a>
                                        </span>
                                    </div>
                                </div>

                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                                <div class="form-footer">
                                    <button type="submit" class="btn btn-primary w-100">{{ 'submitLoginAction'|trans }}</button>
                                </div>
                            </div>
                        </form>
                        <div class="text-center text-secondary mt-3">
                            <a href="{{ path('app_login_help') }}">{{ 'lostAccountAccessLinkLabel'|trans }}</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
