{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'laptopsPageHeading'|trans }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: 'laptopsPageHeading'|trans, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'laptopsPageHeading'|trans }}{% endblock %}

{% block main %}
    {% include '_tabs.html.twig' with {
        tabs: [
            {url: path('app_laptops'), label: 'laptopsInventoryTabLabel'|trans, active: activeTab == 'inventory'},
            {url: path('app_laptops_loans'), label: 'laptopsLoanHistoryTabLabel'|trans, active: activeTab == 'loans'},
        ],
        tabs_action: 'laptop/_' ~ activeTab ~ '_button.html.twig',
    } %}
    <div class="card cm-card--tabbed">
        {# DataTables owns this subtree's DOM from here on - see templates/settings/configuration.html.twig
           for the same note on hot-reload and per-tab includes. #}
        {% include 'laptop/_' ~ activeTab ~ '_content.html.twig' %}
    </div>
{% endblock %}
