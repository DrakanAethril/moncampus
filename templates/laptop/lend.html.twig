{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'lendLaptopPageHeading'|trans }} - {{ laptop.assetTag }}{% endblock %}
{% block page_title %}{{ 'lendLaptopPageHeading'|trans }} - {{ laptop.assetTag }}{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-4">{{ 'laptopAssetTagColumnLabel'|trans }}</dt>
                        <dd class="col-8">{{ laptop.assetTag }}</dd>
                        <dt class="col-4">{{ 'laptopBorrowerColumnLabel'|trans }}</dt>
                        <dd class="col-8">{{ borrower.displayName ?? borrower.username }}</dd>
                    </dl>
                    {{ form_start(form) }}
                        {{ form_errors(form) }}
                        {{ form_row(form.dueAt) }}
                        {{ form_row(form.lentStateNotes) }}
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_laptops_lend', {id: laptop.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                            {{ form_widget(form.submit) }}
                        </div>
                        {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
