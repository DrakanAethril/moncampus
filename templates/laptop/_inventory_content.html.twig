<div data-frankenphp-hot-reload-preserve
     data-controller="datatable"
     data-datatable-url-value="{{ path('app_laptops_data') }}"
     data-datatable-edit-url-template-value="{{ path('app_laptops_edit', {id: '__ID__'}) }}"
     data-datatable-lend-url-template-value="{{ path('app_laptops_lend', {id: '__ID__'}) }}"
     data-datatable-return-url-template-value="{{ path('app_laptops_return', {id: '__ID__'}) }}"
     data-datatable-history-url-template-value="{{ path('app_laptops_history', {id: '__ID__'}) }}"
     data-datatable-deactivate-url-template-value="{{ path('app_laptops_deactivate', {id: '__ID__'}) }}"
     data-datatable-deactivate-token-value="{{ csrf_token('laptop_deactivate') }}"
     data-datatable-edit-label-value="{{ 'editActionLabel'|trans }}"
     data-datatable-lend-label-value="{{ 'lendLaptopButtonLabel'|trans }}"
     data-datatable-return-label-value="{{ 'returnLaptopButtonLabel'|trans }}"
     data-datatable-history-label-value="{{ 'laptopHistoryButtonLabel'|trans }}"
     data-datatable-deactivate-label-value="{{ 'deactivateActionLabel'|trans }}"
     data-datatable-deactivate-confirm-message-value="{{ 'deactivateConfirmMessage'|trans }}"
     data-datatable-deactivate-error-message-value="{{ 'deactivateErrorMessage'|trans }}"
     data-datatable-page-length-value="10"
     data-datatable-columns-value="{{ [
         {data: 'assetTag'},
         {data: 'deviceLabel'},
         {data: 'statusLabel', render: 'badge', classField: 'statusClass'},
         {data: 'borrowerName'},
         {data: 'dueAt'},
         {data: null, render: 'laptopActions'},
     ]|json_encode }}"
     data-datatable-language-value="{{ {
         info: 'datatableInfoLabel'|trans,
         infoEmpty: 'datatableInfoEmptyLabel'|trans,
         infoFiltered: 'datatableInfoFilteredLabel'|trans,
         zeroRecords: 'datatableZeroRecordsLabel'|trans,
         processing: 'datatableProcessingLabel'|trans,
         lengthMenu: 'datatableLengthMenuLabel'|trans,
         search: 'datatableSearchLabel'|trans,
         paginate: {
             next: 'datatablePaginateNextLabel'|trans,
             previous: 'datatablePaginatePreviousLabel'|trans,
         },
     }|json_encode }}">
    <div class="form-check form-switch mb-2" data-datatable-target="includeInactiveWrapper">
        <input class="form-check-input" type="checkbox" id="laptops-include-inactive" data-datatable-target="includeInactive" data-action="change->datatable#reload">
        <label class="form-check-label" for="laptops-include-inactive">{{ 'showInactiveFilterLabel'|trans }}</label>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table table-striped" data-datatable-target="table">
            <thead>
                <tr>
                    <th>{{ 'laptopAssetTagColumnLabel'|trans }}</th>
                    <th>{{ 'laptopDeviceColumnLabel'|trans }}</th>
                    <th>{{ 'laptopStatusColumnLabel'|trans }}</th>
                    <th>{{ 'laptopBorrowerColumnLabel'|trans }}</th>
                    <th>{{ 'laptopDueAtColumnLabel'|trans }}</th>
                    <th class="w-1"></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
