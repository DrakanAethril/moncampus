{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'groupsListPageHeading'|trans }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: 'groupsListPageHeading'|trans, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'groupsListPageHeading'|trans }}{% endblock %}

{% block main %}
    {% include '_tabs.html.twig' with {
        tabs: [
            {url: path('app_settings_groups'), label: 'groupsTabLabel'|trans, active: activeTab == 'groups'},
            {url: path('app_settings_group_types'), label: 'groupTypesTabLabel'|trans, active: activeTab == 'group_types'},
        ],
        tabs_action: 'settings/groups/_' ~ activeTab ~ '_button.html.twig',
    } %}
    <div class="card cm-card--tabbed">
        {# DataTables owns this subtree's DOM from here on - see templates/settings/structure/*
           for the same convention. Only the active tab's content is ever rendered, so switching
           tabs is a real navigation to that tab's own route. #}
        {% include 'settings/groups/_' ~ activeTab ~ '_content.html.twig' %}
    </div>
{% endblock %}
