<div data-frankenphp-hot-reload-preserve
     data-controller="datatable"
     data-datatable-url-value="{{ path('app_settings_structure_school_years_data') }}"
     data-datatable-edit-url-template-value="{{ path('app_settings_structure_school_years_edit', {id: '__ID__'}) }}"
     data-datatable-deactivate-url-template-value="{{ path('app_settings_structure_school_years_deactivate', {id: '__ID__'}) }}"
     data-datatable-deactivate-token-value="{{ csrf_token('structure_deactivate') }}"
     data-datatable-edit-label-value="{{ 'editActionLabel'|trans }}"
     data-datatable-deactivate-label-value="{{ 'deactivateActionLabel'|trans }}"
     data-datatable-deactivate-confirm-message-value="{{ 'deactivateConfirmMessage'|trans }}"
     data-datatable-deactivate-error-message-value="{{ 'deactivateErrorMessage'|trans }}"
     data-datatable-page-length-value="10"
     data-datatable-columns-value="{{ [
         {data: 'startDate'},
         {data: 'endDate'},
         {data: 'creationDate'},
         {data: 'inactiveDate'},
         {data: 'createdByName'},
         {data: 'inactivatedByName'},
         {data: 'lastUpdatedByName'},
         {data: 'lastUpdatedDate'},
         {data: null, render: 'actions'},
     ]|json_encode }}"
     data-datatable-language-value="{{ {
         info: 'datatableInfoLabel'|trans,
         infoEmpty: 'datatableInfoEmptyLabel'|trans,
         infoFiltered: 'datatableInfoFilteredLabel'|trans,
         zeroRecords: 'datatableZeroRecordsLabel'|trans,
         processing: 'datatableProcessingLabel'|trans,
         lengthMenu: 'datatableLengthMenuLabel'|trans,
         search: 'datatableSearchLabel'|trans,
         paginate: {
             next: 'datatablePaginateNextLabel'|trans,
             previous: 'datatablePaginatePreviousLabel'|trans,
         },
     }|json_encode }}">
    <div class="form-check form-switch mb-2" data-datatable-target="includeInactiveWrapper">
        <input class="form-check-input" type="checkbox" id="school-years-include-inactive" data-datatable-target="includeInactive" data-action="change->datatable#reload">
        <label class="form-check-label" for="school-years-include-inactive">{{ 'showInactiveFilterLabel'|trans }}</label>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table table-striped" data-datatable-target="table">
            <thead>
                <tr>
                    <th>{{ 'structureStartDateColumnLabel'|trans }}</th>
                    <th>{{ 'structureEndDateColumnLabel'|trans }}</th>
                    <th>{{ 'structureCreationDateColumnLabel'|trans }}</th>
                    <th>{{ 'structureInactiveDateColumnLabel'|trans }}</th>
                    <th>{{ 'structureCreatedByColumnLabel'|trans }}</th>
                    <th>{{ 'structureInactivatedByColumnLabel'|trans }}</th>
                    <th>{{ 'structureLastUpdatedByColumnLabel'|trans }}</th>
                    <th>{{ 'structureLastUpdatedDateColumnLabel'|trans }}</th>
                    <th class="w-1"></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
