{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editProgramPageHeading' : 'newProgramPageHeading')|trans }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editProgramPageHeading' : 'newProgramPageHeading')|trans }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.name) }}</div>
                    <div class="col-md-6">{{ form_row(form.shortName) }}</div>
                    <div class="col-md-6">{{ form_row(form.cohort) }}</div>
                    <div class="col-md-6">{{ form_row(form.schoolYear) }}</div>
                    <div class="col-md-6">{{ form_row(form.periodGroup) }}</div>
                    <div class="col-md-6"></div>
                    <div class="col-md-6">{{ form_row(form.options) }}</div>
                    <div class="col-md-6">{{ form_row(form.modalities) }}</div>
                    <div class="col-md-6">{{ form_row(form.timetableManagementEnabled) }}</div>
                    <div class="col-md-6">{{ form_row(form.financialManagementEnabled) }}</div>
                    <div class="col-md-6">{{ form_row(form.internshipManagementEnabled) }}</div>
                    <div class="col-md-6">{{ form_row(form.assignmentManagementEnabled) }}</div>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_settings_structure_programs') }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit, {'label': isEdit ? 'submitEditAction' : 'submitCreateAction'}) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
