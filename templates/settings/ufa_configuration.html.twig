{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'ufaConfigurationPageHeading'|trans }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: 'ufaConfigurationPageHeading'|trans, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'ufaConfigurationPageHeading'|trans }}{% endblock %}

{% block main %}
    {% include '_tabs.html.twig' with {
        tabs: [
            {url: path('app_settings_ufa_formation_center'), label: 'internshipFormationCenterTabLabel'|trans, active: activeTab == 'formation_center'},
            {url: path('app_settings_ufa_behavior'), label: 'internshipBehaviorTabLabel'|trans, active: activeTab == 'behavior'},
            {url: path('app_settings_ufa_loan_conditions'), label: 'loanConditionsTabLabel'|trans, active: activeTab == 'loan_conditions'},
        ],
        tabs_action: 'settings/ufa/_' ~ activeTab ~ '_button.html.twig',
    } %}
    <div class="card cm-card--tabbed">
        {# DataTables owns this subtree's DOM from here on - see templates/settings/configuration.html.twig
           for the same note on hot-reload and per-tab includes. #}
        {% include 'settings/ufa/_' ~ activeTab ~ '_content.html.twig' %}
    </div>
{% endblock %}
