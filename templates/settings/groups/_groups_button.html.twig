<div class="d-flex align-items-center gap-2">
    <div data-controller="directory-sync"
         data-directory-sync-url-value="{{ path('app_settings_groups_sync') }}"
         data-directory-sync-token-value="{{ csrf_token('settings_groups_sync') }}"
         data-directory-sync-confirm-message-value="{{ 'groupSyncConfirmMessage'|trans }}"
         data-directory-sync-summary-message-value="{{ 'groupSyncSummaryMessage'|trans }}"
         class="d-flex align-items-center gap-2">
        <span class="d-none small text-success" data-directory-sync-target="summary"></span>
        <span class="d-none small text-danger" data-directory-sync-target="error">{{ 'groupSyncErrorMessage'|trans }}</span>
        <div class="d-none" data-directory-sync-target="spinner">
            <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
        </div>
        <button type="button" class="btn btn-outline-secondary" data-directory-sync-target="button" data-action="directory-sync#run">
            {{ 'groupSyncButtonLabel'|trans }}
        </button>
    </div>
    <a href="{{ path('app_settings_groups_new') }}" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 5l0 14" /><path d="M5 12l14 0" /></svg>
        {{ 'addGroupButtonLabel'|trans }}
    </a>
</div>
