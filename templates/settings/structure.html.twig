{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'structurePageHeading'|trans }}{% endblock %}
{% block page_title %}{{ 'structurePageHeading'|trans }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-header d-flex align-items-center">
            <ul class="nav nav-pills card-header-pills">
                <li class="nav-item">
                    <a href="{{ path('app_settings_structure_sections') }}" class="nav-link {{ activeTab == 'sections' ? 'active' }}">{{ 'sectionsTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_settings_structure_tracks') }}" class="nav-link {{ activeTab == 'tracks' ? 'active' }}">{{ 'tracksTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_settings_structure_cohorts') }}" class="nav-link {{ activeTab == 'cohorts' ? 'active' }}">{{ 'cohortsTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_settings_structure_options') }}" class="nav-link {{ activeTab == 'options' ? 'active' }}">{{ 'optionsTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_settings_structure_modalities') }}" class="nav-link {{ activeTab == 'modalities' ? 'active' }}">{{ 'modalitiesTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_settings_structure_school_years') }}" class="nav-link {{ activeTab == 'school_years' ? 'active' }}">{{ 'schoolYearsTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_settings_structure_programs') }}" class="nav-link {{ activeTab == 'programs' ? 'active' }}">{{ 'programsTabLabel'|trans }}</a>
                </li>
            </ul>
            <div class="ms-auto">
                {% include 'settings/structure/_' ~ activeTab ~ '_button.html.twig' %}
            </div>
        </div>
        <div class="tab-content">
            {# DataTables owns this subtree's DOM from here on (AJAX-rendered rows, pager, wrapper
               markup); tell FrankenPHP's dev hot-reload morph to leave it alone. See
               https://frankenphp.dev/docs/hot-reload/ and templates/directory/*.html.twig. Only
               the active tab's content is ever rendered - see settings/structure/*.html.twig -
               so switching tabs is a real navigation to that tab's own route instead of loading
               all 7 tables' data up front. #}
            {% include 'settings/structure/_' ~ activeTab ~ '_content.html.twig' %}
        </div>
    </div>
{% endblock %}
