{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editPeriodPageHeading' : 'newPeriodPageHeading')|trans }} - {{ periodGroup.name }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editPeriodPageHeading' : 'newPeriodPageHeading')|trans }} - {{ periodGroup.name }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.name) }}</div>
                    <div class="col-md-6">{{ form_row(form.type) }}</div>
                    <div class="col-md-6">{{ form_row(form.startDate) }}</div>
                    <div class="col-md-6">{{ form_row(form.endDate) }}</div>
                    <div class="col-md-12">{{ form_row(form.modalities) }}</div>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_settings_structure_period_groups_periods', {groupId: periodGroup.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit, {'label': isEdit ? 'submitEditAction' : 'submitCreateAction'}) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
