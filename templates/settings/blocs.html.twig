{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'blocsPageHeading'|trans }}{% endblock %}
{% block page_title %}{{ 'blocsPageHeading'|trans }}{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_settings_blocs_new') }}" class="btn btn-primary">{{ 'blocNewButtonLabel'|trans }}</a>
{% endblock %}

{% block main %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                    <tr>
                        <th>{{ 'blocCodeFieldLabel'|trans }}</th>
                        <th>{{ 'blocLabelFieldLabel'|trans }}</th>
                        <th class="w-1"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for bloc in blocs %}
                        <tr>
                            <td>{{ bloc.code }}{% if bloc.inactiveDate %} <span class="badge bg-secondary-lt">{{ 'blocInactiveBadgeLabel'|trans }}</span>{% endif %}</td>
                            <td>{{ bloc.label }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_settings_blocs_edit', {id: bloc.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'editActionLabel'|trans }}</a>
                                {% if not bloc.inactiveDate %}
                                    <form method="post" action="{{ path('app_settings_blocs_deactivate', {id: bloc.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'blocDeactivateConfirmMessage'|trans|e('js') }}')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('settings_blocs_deactivate') }}">
                                        <button type="submit" class="btn btn-sm btn-ghost-danger">{{ 'deactivateActionLabel'|trans }}</button>
                                    </form>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-secondary">{{ 'blocsEmptyMessage'|trans }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
