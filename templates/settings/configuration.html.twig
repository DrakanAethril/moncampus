{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'configurationPageHeading'|trans }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: 'configurationPageHeading'|trans, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'configurationPageHeading'|trans }}{% endblock %}

{% block main %}
    {% include '_tabs.html.twig' with {
        tabs: [
            {url: path('app_settings_structure_sections'), label: 'sectionsTabLabel'|trans, active: activeTab == 'sections'},
            {url: path('app_settings_structure_tracks'), label: 'tracksTabLabel'|trans, active: activeTab == 'tracks'},
            {url: path('app_settings_structure_cohorts'), label: 'cohortsTabLabel'|trans, active: activeTab == 'cohorts'},
            {url: path('app_settings_structure_rooms'), label: 'roomsTabLabel'|trans, active: activeTab == 'rooms'},
            {url: path('app_settings_structure_options'), label: 'optionsTabLabel'|trans, active: activeTab == 'options'},
            {url: path('app_settings_structure_modalities'), label: 'modalitiesTabLabel'|trans, active: activeTab == 'modalities'},
            {url: path('app_settings_structure_lesson_types'), label: 'lessonTypesTabLabel'|trans, active: activeTab == 'lesson_types'},
            {url: path('app_settings_structure_skill_levels'), label: 'skillLevelsTabLabel'|trans, active: activeTab == 'skill_levels'},
            {url: path('app_settings_structure_period_types'), label: 'periodTypesTabLabel'|trans, active: activeTab == 'period_types'},
        ],
        tabs_action: 'settings/structure/_' ~ activeTab ~ '_button.html.twig',
    } %}
    <div class="card cm-card--tabbed">
        {# DataTables owns this subtree's DOM from here on (AJAX-rendered rows, pager, wrapper
           markup); tell FrankenPHP's dev hot-reload morph to leave it alone. See
           https://frankenphp.dev/docs/hot-reload/ and templates/directory/*.html.twig. Only
           the active tab's content is ever rendered - see settings/structure/*.html.twig -
           so switching tabs is a real navigation to that tab's own route instead of loading
           every tab's data up front. #}
        {% include 'settings/structure/_' ~ activeTab ~ '_content.html.twig' %}
    </div>
{% endblock %}
