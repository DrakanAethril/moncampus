{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editInternshipBehaviorPageHeading' : 'newInternshipBehaviorPageHeading')|trans }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editInternshipBehaviorPageHeading' : 'newInternshipBehaviorPageHeading')|trans }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.label) }}</div>
                </div>
                <h4 class="mt-4">{{ 'internshipBehaviorLevelsSectionHeading'|trans }}</h4>
                <div class="row">
                    {% for levelForm in form.levels %}
                        <div class="col-md-6 d-flex align-items-center gap-2 mb-2">
                            <div class="fw-medium">{{ levelForm.vars.data.levelNumber }}</div>
                            <div class="flex-fill">
                                {{ form_widget(levelForm.label) }}
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <div class="d-flex justify-content-between mt-4">
                    <a href="{{ path('app_settings_ufa_behavior') }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit, {'label': isEdit ? 'submitEditAction' : 'submitCreateAction'}) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
