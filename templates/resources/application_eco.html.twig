{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'resourcesEcoAppPageHeading'|trans }}{% endblock %}
{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'resourcesNavLabel'|trans, url: path('app_resources_mobile')},
        {label: 'resourcesEcoAppNavLabel'|trans, url: path('app_resources_eco')},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'resourcesEcoAppPageHeading'|trans }}{% endblock %}

{% block main %}
    <div class="cm-app-hero cm-app-hero--navy mb-3">
        <img class="cm-app-hero__icon" src="{{ asset('images/app-icons/eco/ic_launcher_192.png') }}" alt="">
        <div class="cm-app-hero__body">
            <div class="cm-app-hero__name">{{ resourceApp.name }} — {{ 'resourcesEcoAppSubtitle'|trans }}</div>
            <div class="cm-app-hero__meta">{{ 'resourcesVersionUpdatedText'|trans({'%version%': resourceApp.version, '%date%': resourceApp.updatedAt|date('d/m/Y')}) }}</div>
        </div>
    </div>

    <div class="cm-note mb-3">
        <span class="cm-note__icon">i</span>
        <div>{{ 'resourcesPublicLinksBannerText'|trans }}</div>
    </div>

    <div class="cm-app-cards">
        {% include 'resources/_platform_card.html.twig' with {
            icon_svg: '<svg width="26" height="26" viewBox="0 0 24 24" fill="#2e7d4f"><path d="M17.5 8.5 19 5.8a.4.4 0 0 0-.7-.4l-1.5 2.7A8.9 8.9 0 0 0 12 7.2c-1.7 0-3.3.3-4.8.9L5.7 5.4a.4.4 0 0 0-.7.4l1.5 2.7C3.9 10 2.3 12.6 2 15.6h20c-.3-3-1.9-5.6-4.5-7.1ZM7.5 12.8a.9.9 0 1 1 0-1.8.9.9 0 0 1 0 1.8Zm9 0a.9.9 0 1 1 0-1.8.9.9 0 0 1 0 1.8Z"></path></svg>',
            platform_label: 'resourcesAndroidPlatformLabel'|trans,
            meta_label: 'resourcesApkMetaTemplate'|trans({'%size%': resourceApp.android.size, '%version%': resourceApp.version}),
            qr_svg: resourceApp.android.qr,
            download_url: resourceApp.android.url,
            download_label: 'resourcesDownloadAndroidAction'|trans,
            download_class: 'cm-app-card__download--brand',
            copied_label: 'resourcesCopyLinkCopiedAction'|trans,
            steps: [
                'resourcesAndroidStep1DownloadText'|trans,
                'resourcesEcoAndroidStep2AllowSourceText'|trans,
                'resourcesEcoAndroidStep3PermissionsText'|trans,
            ],
        } only %}
        {% include 'resources/_platform_card.html.twig' with {
            icon_svg: '<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" style="color: var(--cm-ink)"><path d="M16.4 12.9c0-2.4 2-3.6 2.1-3.7-1.1-1.7-2.9-1.9-3.5-1.9-1.5-.2-2.9.9-3.7.9-.8 0-1.9-.9-3.2-.8-1.6 0-3.1 1-4 2.4-1.7 3-.4 7.4 1.2 9.8.8 1.2 1.8 2.5 3.1 2.4 1.2 0 1.7-.8 3.2-.8s1.9.8 3.2.8c1.3 0 2.2-1.2 3-2.4a10 10 0 0 0 1.4-2.8c-.1 0-2.7-1-2.8-3.9ZM14 5.6c.7-.8 1.1-1.9 1-3.1-1 0-2.2.7-2.9 1.5-.6.7-1.2 1.9-1 3 1.1.1 2.2-.6 2.9-1.4Z"></path></svg>',
            platform_label: 'resourcesIosPlatformLabel'|trans,
            meta_label: 'resourcesIpaMetaTemplate'|trans({'%size%': resourceApp.ios.size, '%version%': resourceApp.version}),
            qr_svg: resourceApp.ios.qr,
            download_url: resourceApp.ios.url,
            download_label: 'resourcesDownloadIosAction'|trans,
            download_class: 'cm-app-card__download--navy',
            copied_label: 'resourcesCopyLinkCopiedAction'|trans,
            steps: [
                'resourcesIosStep1SafariText'|trans,
                'resourcesIosStep2TrustProfileText'|trans,
                'resourcesEcoIosStep3PermissionsText'|trans,
            ],
        } only %}
    </div>

    <div class="cm-note cm-note--gold mt-3">
        <span class="cm-note__icon">!</span>
        <div>{{ 'resourcesEcoRaceDayTipText'|trans|raw }}</div>
    </div>
{% endblock %}
