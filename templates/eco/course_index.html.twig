{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'ecoCourseIndexPageHeadingTemplate'|trans({'%name%': parcours.name}) }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'ecoParcoursListPageHeading'|trans, url: path('app_eco_parcours')},
        {label: parcours.name, url: path('app_eco_parcours_configure', {id: parcours.id})},
        {label: 'ecoCourseIndexBreadcrumbLabel'|trans, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'ecoCourseIndexPageHeadingTemplate'|trans({'%name%': parcours.name}) }}{% endblock %}

{% block main %}
    <div class="row g-4 align-items-start">
        <div class="col-12 col-lg-7">
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-vcenter card-table">
                        <thead>
                            <tr>
                                <th>{{ 'ecoCourseNameColumnLabel'|trans }}</th>
                                <th>{{ 'ecoCourseCodeColumnLabel'|trans }}</th>
                                <th>{{ 'ecoCourseModeColumnLabel'|trans }}</th>
                                <th>{{ 'ecoCourseStatusColumnLabel'|trans }}</th>
                                <th>{{ 'ecoCourseRunnersColumnLabel'|trans }}</th>
                                <th class="cm-actions"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for course in courses %}
                                <tr>
                                    <td class="fw-bold">{{ course.name }}</td>
                                    <td><span class="font-monospace fw-bold" style="letter-spacing: 2px;">{{ course.code }}</span></td>
                                    <td>{{ course.mode.labelKey|trans }}</td>
                                    <td><span class="badge {{ course.status.badgeClass }}">{{ course.status.labelKey|trans }}</span></td>
                                    <td>{{ course.runners|length > 0 ? course.runners|length : '—' }}</td>
                                    <td class="cm-actions">
                                        {% if course.status.value == 'in_progress' %}
                                            <a href="{{ path('app_eco_course_live', {id: course.id}) }}" class="cm-action--positive">{{ 'ecoActionLiveLabel'|trans }}</a>
                                            <form method="post" action="{{ path('app_eco_course_close', {id: course.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('eco_course_close') }}">
                                                <button type="submit" class="cm-action--danger">{{ 'ecoActionCloseLabel'|trans }}</button>
                                            </form>
                                        {% elseif course.status.value == 'closed' %}
                                            <a href="{{ path('app_eco_course_results', {id: course.id}) }}" class="cm-action--neutral">{{ 'ecoActionResultsLabel'|trans }}</a>
                                            <form method="post" action="{{ path('app_eco_course_duplicate', {id: course.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('eco_course_duplicate') }}">
                                                <button type="submit" class="cm-action--neutral">{{ 'ecoActionDuplicateLabel'|trans }}</button>
                                            </form>
                                        {% else %}
                                            <form method="post" action="{{ path('app_eco_course_start', {id: course.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('eco_course_start') }}">
                                                <button type="submit" class="cm-action--positive">{{ 'ecoActionStartLabel'|trans }}</button>
                                            </form>
                                            <a href="{{ path('app_eco_course_edit', {id: course.id}) }}" class="cm-action--warning">{{ 'ecoActionEditLabel'|trans }}</a>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="6" class="text-secondary">{{ 'ecoCourseNoneYetText'|trans }}</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="card-footer text-secondary" style="font-size: 12.5px;">
                    {{ 'ecoCourseIndexNoteText'|trans }}
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-5">
            <div class="card">
                <div class="card-body d-flex flex-column gap-3">
                    <div class="cm-subhead">
                        <div class="cm-subhead__title">{{ 'ecoCourseNewTitle'|trans }}</div>
                    </div>
                    {{ form_start(form) }}
                    {{ form_errors(form) }}
                    {{ form_row(form.name) }}
                    {% set modeDescriptionKeys = {
                        'imposed_order': 'ecoCourseModeImposedOrderDescription',
                        'free_order': 'ecoCourseModeFreeOrderDescription',
                        'score': 'ecoCourseModeScoreDescription',
                    } %}
                    <div class="d-flex flex-column gap-2">
                        <label class="form-label">{{ 'ecoCourseModeFieldLabel'|trans }}</label>
                        {% for choice in form.mode %}
                            <label class="cm-radiocard">
                                {{ form_widget(choice) }}
                                <span class="cm-radiocard__dot"></span>
                                <span>
                                    <span class="cm-radiocard__title d-block">{{ choice.vars.label|trans }}</span>
                                    <span class="cm-radiocard__desc">{{ modeDescriptionKeys[choice.vars.value]|trans }}</span>
                                </span>
                            </label>
                        {% endfor %}
                    </div>
                    {{ form_row(form.mapVisibility) }}
                    <div class="form-hint">{{ 'ecoCourseMapVisibilityHintText'|trans }}</div>
                    <div class="d-flex flex-column gap-2">
                        {{ form_row(form.teamsEnabled, {row_attr: {class: 'form-switch'}}) }}
                        {{ form_row(form.safetyAlertsEnabled, {row_attr: {class: 'form-switch'}}) }}
                    </div>
                    {{ form_widget(form.submit, {attr: {class: 'btn btn-primary w-100'}}) }}
                    {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
