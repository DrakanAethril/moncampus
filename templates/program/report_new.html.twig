{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editReportPageHeading' : 'newReportPageHeading')|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editReportPageHeading' : 'newReportPageHeading')|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.title) }}</div>
                    <div class="col-md-6">{{ form_row(form.day) }}</div>
                    <div class="col-md-6">
                        <label class="form-label" for="referee">{{ 'reportRefereeFieldLabel'|trans }}</label>
                        <select id="referee" name="referee" class="form-select"
                                data-controller="tom-select"
                                data-tom-select-url-value="{{ path('app_program_settings_reports_referees_search', {id: program.id}) }}"
                                data-tom-select-placeholder-value="{{ 'reportRefereeFieldLabel'|trans }}">
                            {% if form.vars.data and form.vars.data.referee %}
                                <option value="{{ form.vars.data.referee.id }}" selected>{{ form.vars.data.referee.displayName ?? form.vars.data.referee.username }}</option>
                            {% endif %}
                        </select>
                    </div>
                    {% if form.options is defined %}
                        <div class="col-md-6">{{ form_row(form.options) }}</div>
                    {% endif %}
                    <div class="col-12">{{ form_row(form.description, {attr: {class: 'd-none', 'data-controller': 'hugerte-editor'}}) }}</div>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_program_settings_reports', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit, {'label': isEdit ? 'submitEditAction' : 'submitCreateAction'}) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
