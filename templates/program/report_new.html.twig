{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editReportPageHeading' : 'newReportPageHeading')|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editReportPageHeading' : 'newReportPageHeading')|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        {{ form_errors(form) }}
                        {{ form_row(form.title) }}
                        {{ form_row(form.day) }}
                        {{ form_row(form.referee) }}
                        {% if form.options is defined %}
                            {{ form_row(form.options) }}
                        {% endif %}
                        {{ form_row(form.description, {attr: {class: 'd-none', 'data-controller': 'hugerte-editor'}}) }}
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_program_settings_reports', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                            {{ form_widget(form.submit) }}
                        </div>
                        {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
