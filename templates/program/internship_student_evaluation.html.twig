{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'internshipEvaluatePageHeading'|trans }} — {{ student.displayName ?? student.username }}{% endblock %}
{% block page_title %}{{ 'internshipEvaluatePageHeading'|trans }} — {{ student.displayName ?? student.username }} ({{ period.name }}){% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                {{ form_row(form.remarksText) }}
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_program_internship_students_evaluations', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
