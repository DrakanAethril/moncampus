{% extends 'layout/app.html.twig' %}

{# Expects `member` (the User whose options are being edited), `program`, `form`, and
   `backRoute` (the students or teachers settings tab route name to return to). #}
{% block title %}{{ 'memberOptionsPageHeading'|trans }} - {{ member.displayName ?? member.username }}{% endblock %}
{% block page_title %}{{ 'memberOptionsPageHeading'|trans }} - {{ member.displayName ?? member.username }}{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        {{ form_errors(form) }}
                        {{ form_row(form.options) }}
                        <div class="d-flex justify-content-between">
                            <a href="{{ path(backRoute, {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                            {{ form_widget(form.submit) }}
                        </div>
                        {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
