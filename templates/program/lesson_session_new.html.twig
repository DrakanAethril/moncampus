{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editLessonSessionPageHeading' : 'newLessonSessionPageHeading')|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editLessonSessionPageHeading' : 'newLessonSessionPageHeading')|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        {{ form_errors(form) }}
                        {{ form_row(form.day) }}
                        {{ form_row(form.startHour) }}
                        {{ form_row(form.endHour) }}
                        {{ form_row(form.topic) }}
                        {{ form_row(form.title) }}
                        {{ form_row(form.teacher) }}
                        {{ form_row(form.classRoom) }}
                        {{ form_row(form.lessonType) }}
                        {% if form.options is defined %}
                            {{ form_row(form.options) }}
                        {% endif %}
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_program_settings_timetable', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                            {{ form_widget(form.submit) }}
                        </div>
                        {{ form_rest(form) }}
                    {{ form_end(form) }}
                    {% if isEdit %}
                        <form method="post" action="{{ path('app_program_settings_timetable_sessions_remove', {id: program.id, sessionId: form.vars.data.id}) }}" class="mt-3" onsubmit="return confirm('{{ 'removeLessonSessionConfirmMessage'|trans|e('js') }}')">
                            <input type="hidden" name="_token" value="{{ csrf_token('program_settings_timetable_remove') }}">
                            <button type="submit" class="btn btn-ghost-danger">{{ 'removeActionLabel'|trans }}</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
