{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'programInternshipPageHeading'|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ 'programInternshipPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-header d-flex align-items-center">
            <ul class="nav nav-pills card-header-pills">
                <li class="nav-item">
                    <a href="{{ path('app_program_internship_tutors', {id: program.id}) }}" class="nav-link {{ activeTab == 'tutors' ? 'active' }}">{{ 'programInternshipTutorsTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_program_internship_skills', {id: program.id}) }}" class="nav-link {{ activeTab == 'skills' ? 'active' }}">{{ 'programInternshipSkillsTabLabel'|trans }}</a>
                </li>
                {% if program.topicSkillManagementEnabled %}
                    <li class="nav-item">
                        <a href="{{ path('app_program_internship_topic_skills', {id: program.id}) }}" class="nav-link {{ activeTab == 'topic_skills' ? 'active' }}">{{ 'programInternshipTopicSkillsTabLabel'|trans }}</a>
                    </li>
                {% endif %}
                <li class="nav-item">
                    <a href="{{ path('app_program_internship_info', {id: program.id}) }}" class="nav-link {{ activeTab == 'info' ? 'active' }}">{{ 'programInternshipInfoTabLabel'|trans }}</a>
                </li>
            </ul>
            <div class="ms-auto">
                {% include 'program/internship/_' ~ activeTab ~ '_button.html.twig' %}
            </div>
        </div>
        <div class="tab-content">
            {# Same reasoning as templates/program/settings.html.twig: only the active tab's
               content is ever rendered, and DataTables owns its subtree's DOM from here on. #}
            {% include 'program/internship/_' ~ activeTab ~ '_content.html.twig' %}
        </div>
    </div>
{% endblock %}
