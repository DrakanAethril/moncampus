{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'programInternshipPageHeading'|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ 'programInternshipPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-header d-flex align-items-center">
            <ul class="nav nav-pills card-header-pills">
                <li class="nav-item">
                    <a href="{{ path('app_program_internship_tutors', {id: program.id}) }}" class="nav-link {{ activeTab == 'tutors' ? 'active' }}">{{ 'programInternshipTutorsTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_program_internship_evaluation_periods', {id: program.id}) }}" class="nav-link {{ activeTab == 'evaluation_periods' ? 'active' }}">{{ 'programInternshipEvaluationPeriodsTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_program_internship_denomination', {id: program.id}) }}" class="nav-link {{ activeTab == 'denomination' ? 'active' }}">{{ 'programInternshipDenominationTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_program_internship_contract_modalities', {id: program.id}) }}" class="nav-link {{ activeTab == 'contract_modalities' ? 'active' }}">{{ 'programInternshipContractModalitiesTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_program_internship_exam_modalities', {id: program.id}) }}" class="nav-link {{ activeTab == 'exam_modalities' ? 'active' }}">{{ 'programInternshipExamModalitiesTabLabel'|trans }}</a>
                </li>
            </ul>
            <div class="ms-auto">
                {% include 'program/internship/_' ~ activeTab ~ '_button.html.twig' %}
            </div>
        </div>
        <div class="tab-content">
            {# Same reasoning as templates/program/settings.html.twig: only the active tab's
               content is ever rendered, and DataTables owns its subtree's DOM from here on. #}
            {% include 'program/internship/_' ~ activeTab ~ '_content.html.twig' %}
        </div>
    </div>
{% endblock %}
