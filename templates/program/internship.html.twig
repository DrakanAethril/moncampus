{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'programInternshipPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: 'programInternshipNavLabel'|trans, url: path('app_program_internship', {id: program.id})},
        {label: program.shortName, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'programInternshipPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    {% include '_tabs.html.twig' with {
        tabs: [
            {url: path('app_program_internship_tutors', {id: program.id}), label: 'programInternshipTutorsTabLabel'|trans, active: activeTab == 'tutors'},
            {url: path('app_program_internship_evaluation_periods', {id: program.id}), label: 'programInternshipEvaluationPeriodsTabLabel'|trans, active: activeTab == 'evaluation_periods'},
            {url: path('app_program_internship_denomination', {id: program.id}), label: 'programInternshipDenominationTabLabel'|trans, active: activeTab == 'denomination'},
            {url: path('app_program_internship_contract_modalities', {id: program.id}), label: 'programInternshipContractModalitiesTabLabel'|trans, active: activeTab == 'contract_modalities'},
            {url: path('app_program_internship_exam_modalities', {id: program.id}), label: 'programInternshipExamModalitiesTabLabel'|trans, active: activeTab == 'exam_modalities'},
        ],
        tabs_action: 'program/internship/_' ~ activeTab ~ '_button.html.twig',
    } %}
    <div class="card cm-card--tabbed">
        {# Same reasoning as templates/program/settings.html.twig: only the active tab's
           content is ever rendered, and DataTables owns its subtree's DOM from here on. #}
        {% include 'program/internship/_' ~ activeTab ~ '_content.html.twig' %}
    </div>
{% endblock %}
