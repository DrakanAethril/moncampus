{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editTopicGroupPageHeading' : 'newTopicGroupPageHeading')|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editTopicGroupPageHeading' : 'newTopicGroupPageHeading')|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.name) }}</div>
                    {% if form.options is defined %}
                        <div class="col-12">{{ form_row(form.options) }}</div>
                    {% endif %}
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_program_timetable_settings_topic_groups', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit, {'label': isEdit ? 'submitEditAction' : 'submitCreateAction'}) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
