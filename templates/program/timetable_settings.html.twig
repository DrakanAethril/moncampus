{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'programTimetableSettingsPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: 'programSettingsTimetableTabLabel'|trans, url: path('app_program_timetable_settings', {id: program.id})},
        {label: program.shortName, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'programTimetableSettingsPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    {% include '_tabs.html.twig' with {
        tabs: [
            {url: path('app_program_timetable_settings', {id: program.id}), label: 'programSettingsTimetableTabLabel'|trans, active: activeTab == 'timetable'},
            {url: path('app_program_timetable_settings_topic_groups', {id: program.id}), label: 'programSettingsTopicGroupsTabLabel'|trans, active: activeTab == 'topic_groups'},
            {url: path('app_program_timetable_settings_topics', {id: program.id}), label: 'programSettingsTopicsTabLabel'|trans, active: activeTab == 'topics'},
            {url: path('app_program_timetable_settings_team', {id: program.id}), label: 'programSettingsTeamTabLabel'|trans, active: activeTab == 'team'},
        ],
        tabs_action: 'program/settings/_' ~ activeTab ~ '_button.html.twig',
    } %}
    <div class="card cm-card--tabbed">
        {# Same reasoning as templates/settings/configuration.html.twig: only the active tab's
           content is ever rendered, and DataTables owns this subtree's DOM from here on. #}
        {% include 'program/settings/_' ~ activeTab ~ '_content.html.twig' %}
    </div>
{% endblock %}
