{% extends 'layout/app.html.twig' %}

{% block title %}{{ quizInstance.name }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: program.shortName, url: path('app_program_quiz_mine', {id: program.id})},
        {label: 'programQuizNavLabel'|trans, url: path('app_program_quiz_mine', {id: program.id})},
        {label: 'programQuizCorrectionBreadcrumbLabel'|trans, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}
    {{ 'programQuizCorrectionHeadingTemplate'|trans({'%name%': quizInstance.name}) }}
    <span class="badge {{ attempt.scorePercent >= 70 ? 'bg-green-lt' : (attempt.scorePercent >= 40 ? 'bg-warning-lt' : 'bg-red-lt') }} ms-2" style="font-weight:700;font-size:15px;padding:6px 14px;">{{ attempt.correctCount }} / {{ attempt.questionTotal }} · {{ attempt.scorePercent }} %</span>
    <span class="text-secondary small fw-normal ms-2">{{ 'programQuizAttemptMetaTemplate'|trans({'%number%': attempt.attemptNumber, '%date%': attempt.submittedAt ? attempt.submittedAt|date('d/m/Y') : ''}) }}</span>
{% endblock %}
{% block page_actions %}
    <a href="{{ path('app_program_quiz_take', {id: program.id, instanceId: quizInstance.id}) }}" class="btn btn-primary">{{ 'programQuizRetryAction'|trans }}</a>
{% endblock %}

{% block main %}
    {% include 'program/_quiz_attempt_breakdown.html.twig' with {attempt: attempt} %}
{% endblock %}
