{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'quizLiveJoinPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: program.shortName, url: path('app_program_quiz_mine', {id: program.id})},
        {label: 'quizLiveJoinPageHeading'|trans, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'quizLiveJoinPageHeading'|trans }}{% endblock %}

{% block main %}
    <div class="card" style="max-width: 480px;">
        <div class="card-body d-flex flex-column gap-3">
            <div>
                <div class="text-secondary text-uppercase" style="font-size: 12px; letter-spacing: 1.5px;">{{ 'quizLiveJoinEyebrowTemplate'|trans({'%program%': program.shortName}) }}</div>
                <div class="fw-bold" style="font-size: 20px;">{{ session.quizInstance.name }}</div>
                <div class="text-secondary" style="font-size: 12.5px;">{{ 'quizLiveJoinHostedByTemplate'|trans({'%host%': session.host.displayName ?? session.host.username}) }}</div>
            </div>
            {# data-turbo="false": redirects into the dark full-bleed play shell - see
               quiz_live_created.html.twig's comment on the same Turbo-morph issue. #}
            <form method="post" action="{{ path('app_program_quiz_live_join', {id: program.id, sessionId: session.id}) }}" class="d-flex flex-column gap-3" data-turbo="false">
                <input type="hidden" name="_token" value="{{ csrf_token('quiz_live_join') }}">
                <div>
                    <label class="form-label" for="quiz-live-display-name">{{ 'quizLiveDisplayNameFieldLabel'|trans }}</label>
                    <input type="text" class="form-control" id="quiz-live-display-name" name="displayName" value="{{ defaultDisplayName }}" maxlength="100" required>
                    <div class="form-hint">{{ 'quizLiveDisplayNameFieldHint'|trans }}</div>
                </div>
                <button type="submit" class="btn btn-warning">{{ 'quizLiveJoinSubmitAction'|trans }}</button>
            </form>
        </div>
    </div>
{% endblock %}
