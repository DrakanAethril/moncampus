<div class="card"
     data-controller="static-table"
     data-static-table-order-column-value="0">
    <div class="table-responsive">
        <table class="table table-vcenter card-table table-striped" data-static-table-target="table">
            <thead>
                <tr>
                    <th>{{ 'topicGroupNameColumnLabel'|trans }}</th>
                    <th>{{ 'topicGroupOptionsColumnLabel'|trans }}</th>
                    <th class="cm-actions"></th>
                </tr>
            </thead>
            <tbody>
                {% for topicGroup in topicGroups %}
                    <tr>
                        <td>{{ topicGroup.name }}</td>
                        <td>
                            {% for option in topicGroup.options %}
                                <span class="badge me-1" style="background-color: {{ option.color }}; color: #fff;">{{ option.shortName }}</span>
                            {% endfor %}
                        </td>
                        <td class="cm-actions">
                            <a href="{{ path('app_program_timetable_settings_topic_groups_edit', {id: program.id, topicGroupId: topicGroup.id}) }}" class="cm-action--warning">{{ 'editActionLabel'|trans }}</a>
                            <form method="post" action="{{ path('app_program_timetable_settings_topic_groups_deactivate', {id: program.id, topicGroupId: topicGroup.id}) }}" onsubmit="return confirm('{{ 'deactivateConfirmMessage'|trans|e('js') }}')">
                                <input type="hidden" name="_token" value="{{ csrf_token('program_settings_topic_groups_deactivate') }}">
                                <button type="submit" class="cm-action--danger">{{ 'deactivateActionLabel'|trans }}</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-secondary">{{ 'topicGroupsEmptyMessage'|trans }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
