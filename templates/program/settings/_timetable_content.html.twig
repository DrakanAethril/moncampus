<div data-frankenphp-hot-reload-preserve
     data-controller="lesson-timetable"
     data-lesson-timetable-feed-url-value="{{ path('app_program_timetable_settings_feed', {id: program.id}) }}"
     data-lesson-timetable-editable-value="true"
     data-lesson-timetable-new-session-url-template-value="{{ path('app_program_timetable_settings_sessions_new', {id: program.id, start: '__START__', end: '__END__'}) }}"
     data-lesson-timetable-move-url-template-value="{{ path('app_program_timetable_settings_sessions_move', {id: program.id, sessionId: '__ID__'}) }}"
     data-lesson-timetable-move-token-value="{{ csrf_token('program_settings_timetable_move') }}"
     data-lesson-timetable-move-error-message-value="{{ 'lessonSessionMoveErrorMessage'|trans }}">
</div>
