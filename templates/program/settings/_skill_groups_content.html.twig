{% include 'program/settings/_skill_groups_toggle.html.twig' %}

{% if not program.customSkillCriteriaEnabled %}
    <p class="text-secondary">{{ 'programCustomSkillCriteriaGlobalListHelp'|trans }}</p>
    {% if globalSkillGroups is empty %}
        <p class="text-secondary">{{ 'internshipSkillGroupEmptyLabel'|trans }}</p>
    {% else %}
        <div class="list-group">
            {% for group in globalSkillGroups %}
                <div class="list-group-item">
                    <div class="fw-medium">{{ group.label }}</div>
                    {% if group.skills is not empty %}
                        <ul class="mb-0 text-secondary">
                            {% for skill in group.skills %}
                                <li>{{ skill.label }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% else %}
<div data-frankenphp-hot-reload-preserve
     data-controller="datatable"
     data-datatable-url-value="{{ path('app_program_settings_skill_groups_data', {id: program.id}) }}"
     data-datatable-edit-url-template-value="{{ path('app_program_settings_skill_groups_edit', {id: program.id, groupId: '__ID__'}) }}"
     data-datatable-deactivate-url-template-value="{{ path('app_program_settings_skill_groups_deactivate', {id: program.id, groupId: '__ID__'}) }}"
     data-datatable-deactivate-token-value="{{ csrf_token('program_settings_deactivate') }}"
     data-datatable-edit-label-value="{{ 'editActionLabel'|trans }}"
     data-datatable-deactivate-label-value="{{ 'deactivateActionLabel'|trans }}"
     data-datatable-deactivate-confirm-message-value="{{ 'deactivateConfirmMessage'|trans }}"
     data-datatable-deactivate-error-message-value="{{ 'deactivateErrorMessage'|trans }}"
     data-datatable-page-length-value="10"
     data-datatable-columns-value="{{ [
         {data: 'label', render: 'html'},
         {data: null, render: 'actions'},
     ]|json_encode }}"
     data-datatable-language-value="{{ {
         info: 'datatableInfoLabel'|trans,
         infoEmpty: 'datatableInfoEmptyLabel'|trans,
         infoFiltered: 'datatableInfoFilteredLabel'|trans,
         zeroRecords: 'datatableZeroRecordsLabel'|trans,
         processing: 'datatableProcessingLabel'|trans,
         lengthMenu: 'datatableLengthMenuLabel'|trans,
         search: 'datatableSearchLabel'|trans,
         paginate: {
             next: 'datatablePaginateNextLabel'|trans,
             previous: 'datatablePaginatePreviousLabel'|trans,
         },
     }|json_encode }}">
    <div class="form-check form-switch mb-2" data-datatable-target="includeInactiveWrapper">
        <input class="form-check-input" type="checkbox" id="internship-skills-include-inactive" data-datatable-target="includeInactive" data-action="change->datatable#reload">
        <label class="form-check-label" for="internship-skills-include-inactive">{{ 'showInactiveFilterLabel'|trans }}</label>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table table-striped" data-datatable-target="table">
            <thead>
                <tr>
                    <th>{{ 'internshipSkillGroupLabelColumnLabel'|trans }}</th>
                    <th class="w-1"></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
{% endif %}
