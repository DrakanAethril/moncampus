<div class="d-flex align-items-center justify-content-between mb-3 p-3 border rounded">
    <div>
        <div class="fw-medium">{{ 'programCustomSkillCriteriaToggleLabel'|trans }}</div>
        <div class="text-secondary small">
            {{ (program.customSkillCriteriaEnabled ? 'programCustomSkillCriteriaEnabledHelp' : 'programCustomSkillCriteriaDisabledHelp')|trans }}
        </div>
    </div>
    <form method="post" action="{{ path('app_program_settings_skill_groups_toggle_custom', {id: program.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('program_settings_toggle_custom_skill_criteria') }}">
        <button type="submit" class="btn {{ program.customSkillCriteriaEnabled ? 'btn-outline-secondary' : 'btn-outline-primary' }}">
            {{ (program.customSkillCriteriaEnabled ? 'programCustomSkillCriteriaDisableAction' : 'programCustomSkillCriteriaEnableAction')|trans }}
        </button>
    </form>
</div>
