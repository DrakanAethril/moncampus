{% extends 'layout/app.html.twig' %}

{# Route names/heading follow the same "{memberType}_add"-family naming for all three member
   types (students/teachers/referents) - see ProgramSettingsController. #}
{% set routes = {
    students: {tab: 'app_program_settings_students', data: 'app_program_settings_students_add_data', submit: 'app_program_settings_students_add_submit', heading: 'addStudentsPageHeading'},
    teachers: {tab: 'app_program_settings_teachers', data: 'app_program_settings_teachers_add_data', submit: 'app_program_settings_teachers_add_submit', heading: 'addTeachersPageHeading'},
    referents: {tab: 'app_program_settings_referents', data: 'app_program_settings_referents_add_data', submit: 'app_program_settings_referents_add_submit', heading: 'addReferentsPageHeading'},
}[memberType] %}

{% block title %}{{ routes.heading|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ routes.heading|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            <div class="mb-3">
                <a href="{{ path(routes.tab, {id: program.id}) }}" class="btn btn-link ps-0">{{ 'cancelAction'|trans }}</a>
            </div>
            <div data-frankenphp-hot-reload-preserve
                 data-controller="datatable"
                 data-datatable-url-value="{{ path(routes.data, {id: program.id}) }}"
                 data-datatable-add-url-template-value="{{ path(routes.submit, {id: program.id, userId: '__ID__'}) }}"
                 data-datatable-add-token-value="{{ csrf_token('program_settings_add') }}"
                 data-datatable-add-label-value="{{ 'addActionLabel'|trans }}"
                 data-datatable-add-error-message-value="{{ 'addErrorMessage'|trans }}"
                 data-datatable-page-length-value="10"
                 data-datatable-columns-value="{{ [
                     {data: 'fullName'},
                     {data: 'username'},
                     {data: 'email'},
                     {data: null, render: 'add'},
                 ]|json_encode }}"
                 data-datatable-language-value="{{ {
                     info: 'datatableInfoLabel'|trans,
                     infoEmpty: 'datatableInfoEmptyLabel'|trans,
                     infoFiltered: 'datatableInfoFilteredLabel'|trans,
                     zeroRecords: 'datatableZeroRecordsLabel'|trans,
                     processing: 'datatableProcessingLabel'|trans,
                     lengthMenu: 'datatableLengthMenuLabel'|trans,
                     search: 'datatableSearchLabel'|trans,
                     paginate: {
                         next: 'datatablePaginateNextLabel'|trans,
                         previous: 'datatablePaginatePreviousLabel'|trans,
                     },
                 }|json_encode }}">
                <div class="table-responsive">
                    <table class="table table-vcenter card-table table-striped" data-datatable-target="table">
                        <thead>
                            <tr>
                                <th>{{ 'userFullNameColumnLabel'|trans }}</th>
                                <th>{{ 'userLoginColumnLabel'|trans }}</th>
                                <th>{{ 'accountEmailLabel'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
