{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editInternshipSkillLevelPageHeading' : 'newInternshipSkillLevelPageHeading')|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editInternshipSkillLevelPageHeading' : 'newInternshipSkillLevelPageHeading')|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        {{ form_errors(form) }}
                        {{ form_row(form.label) }}
                        {{ form_row(form.color) }}
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_program_settings_skill_levels', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                            {{ form_widget(form.submit) }}
                        </div>
                        {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
