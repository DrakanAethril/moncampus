{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editInternshipTutorLinkPageHeading' : 'newInternshipTutorLinkPageHeading')|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editInternshipTutorLinkPageHeading' : 'newInternshipTutorLinkPageHeading')|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.student) }}</div>
                    <div class="col-md-6"></div>
                    <div class="col-md-6">{{ form_row(form.tutorFirstName) }}</div>
                    <div class="col-md-6">{{ form_row(form.tutorLastName) }}</div>
                    <div class="col-md-6">{{ form_row(form.tutorEmail) }}</div>
                    <div class="col-md-6">{{ form_row(form.tutorPhone) }}</div>
                    <div class="col-md-6">{{ form_row(form.contractStartDate) }}</div>
                    <div class="col-md-6">{{ form_row(form.contractEndDate) }}</div>
                </div>
                <div data-controller="enterprise-picker">
                    {{ form_row(form.enterprise, {attr: {'data-enterprise-picker-target': 'select', 'data-action': 'change->enterprise-picker#toggle'}}) }}
                    <div data-enterprise-picker-target="newFields" class="row">
                        <div class="col-md-6">{{ form_row(form.newEnterpriseName) }}</div>
                        <div class="col-md-6">{{ form_row(form.newEnterpriseAddress) }}</div>
                    </div>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_program_internship_tutors', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit, {'label': isEdit ? 'submitEditAction' : 'submitCreateAction'}) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
