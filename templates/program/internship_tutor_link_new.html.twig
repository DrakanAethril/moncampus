{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editInternshipTutorLinkPageHeading' : 'newInternshipTutorLinkPageHeading')|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editInternshipTutorLinkPageHeading' : 'newInternshipTutorLinkPageHeading')|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        {{ form_errors(form) }}
                        {{ form_row(form.student) }}
                        {{ form_row(form.tutorFirstName) }}
                        {{ form_row(form.tutorLastName) }}
                        {{ form_row(form.tutorEmail) }}
                        {{ form_row(form.tutorPhone) }}
                        {{ form_row(form.companyName) }}
                        {{ form_row(form.companyAddress) }}
                        {{ form_row(form.contractStartDate) }}
                        {{ form_row(form.contractEndDate) }}
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_program_internship_tutors', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                            {{ form_widget(form.submit) }}
                        </div>
                        {{ form_rest(form) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
