{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'programStudentsPageHeading'|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ 'programStudentsPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    {% if students|length > 0 %}
        <div class="row row-cards">
            {% for student in students %}
                {{ include('program/_user_card.html.twig', {user: student, options: optionsByStudentId[student.id] ?? []}) }}
            {% endfor %}
        </div>
    {% else %}
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-body">
                        <p class="text-secondary mb-0">{{ 'programStudentsEmptyLabel'|trans }}</p>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
