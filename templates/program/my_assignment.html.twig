{% extends 'layout/app.html.twig' %}

{% block title %}{{ assignment.title }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ assignment.title }}{% endblock %}

{% block main %}
    <div class="mb-3">
        <a href="{{ path('app_program_my_assignments', {id: program.id}) }}" class="btn btn-link ps-0">{{ 'backToAssignmentsAction'|trans }}</a>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="mb-2">
                <span class="text-secondary">{{ 'assignmentDueDateFieldLabel'|trans }}:</span>
                {{ assignment.dueDate|date('d/m/Y') }}
            </div>
            {% if assignment.description %}
                <div style="white-space: pre-wrap;">{{ assignment.description }}</div>
            {% endif %}
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">{{ 'assignmentSubmissionFilesColumnLabel'|trans }}</h3>
        </div>
        <div class="card-body">
            {% if submission and submission.files is not empty %}
                <div class="list-group list-group-flush mb-3">
                    {% for file in submission.files %}
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <a href="{{ file_url(file.storageKey) }}" target="_blank" rel="noopener">{{ file.originalFilename }}</a>
                            <form method="post" action="{{ path('app_program_my_assignment_files_delete', {id: program.id, assignmentId: assignment.id, fileId: file.id}) }}" onsubmit="return confirm('{{ 'assignmentSubmissionFileRemoveConfirmMessage'|trans|e('js') }}')">
                                <input type="hidden" name="_token" value="{{ csrf_token('assignment_submission_file_delete') }}">
                                <button type="submit" class="btn btn-sm btn-ghost-danger">{{ 'removeActionLabel'|trans }}</button>
                            </form>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-secondary">{{ 'assignmentSubmissionEmptyMessage'|trans }}</p>
            {% endif %}

            {{ form_start(form, {action: path('app_program_my_assignment', {id: program.id, assignmentId: assignment.id}), attr: {enctype: 'multipart/form-data'}}) }}
                {{ form_errors(form) }}
                {{ form_row(form.file) }}
                {{ form_widget(form.submit) }}
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
