{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'programExportsPageHeading'|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ 'programExportsPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-header d-print-none">
            <ul class="nav nav-pills card-header-pills">
                <li class="nav-item">
                    <a href="{{ path('app_program_exports_signature', {id: program.id}) }}" class="nav-link {{ activeTab == 'signature' ? 'active' }}">{{ 'exportsSignatureTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_program_exports_invoicing', {id: program.id}) }}" class="nav-link {{ activeTab == 'invoicing' ? 'active' }}">{{ 'exportsInvoicingTabLabel'|trans }}</a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_program_exports_tsf', {id: program.id}) }}" class="nav-link {{ activeTab == 'tsf' ? 'active' }}">{{ 'exportsTsfTabLabel'|trans }}</a>
                </li>
            </ul>
        </div>
        <div class="card-body">
            {% include 'program/exports/_' ~ activeTab ~ '.html.twig' %}
        </div>
    </div>
{% endblock %}
