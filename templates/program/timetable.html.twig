{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'programTimetablePageHeading'|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ 'programTimetablePageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            <div class="cm-calendar"
                 data-frankenphp-hot-reload-preserve
                 data-controller="lesson-timetable"
                 data-lesson-timetable-feed-url-value="{{ path('app_program_timetable_feed', {id: program.id}) }}"
                 data-lesson-timetable-editable-value="false"
                 {# FullCalendar's validRange.end is exclusive, hence the +1 day - the calendar should still let you view the last effective day itself. #}
                 {% if program.effectiveStartDate %}data-lesson-timetable-valid-range-start-value="{{ program.effectiveStartDate|date('Y-m-d') }}"{% endif %}
                 {% if program.effectiveEndDate %}data-lesson-timetable-valid-range-end-value="{{ program.effectiveEndDate|date_modify('+1 day')|date('Y-m-d') }}"{% endif %}>
            </div>
            {% include 'program/_timetable_legend.html.twig' %}
        </div>
    </div>
{% endblock %}
