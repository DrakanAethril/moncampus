{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'skillsPageHeading'|trans }} - {{ skillGroup.label }}{% endblock %}
{% block page_title %}{{ 'skillsPageHeading'|trans }} - {{ skillGroup.label }}{% endblock %}

{% block main %}
    <div class="mb-3">
        <a href="{{ path('app_program_settings_skill_groups', {id: program.id}) }}">&laquo; {{ 'backToInternshipSkillGroupsLinkLabel'|trans }}</a>
    </div>
    <div class="card">
        <div class="card-header d-flex align-items-center">
            <div class="ms-auto">
                <a href="{{ path('app_program_settings_skill_groups_skills_new', {id: program.id, groupId: skillGroup.id}) }}" class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 5l0 14" /><path d="M5 12l14 0" /></svg>
                    {{ 'addSkillButtonLabel'|trans }}
                </a>
            </div>
        </div>
        <div class="tab-content">
            <div data-frankenphp-hot-reload-preserve
                 data-controller="datatable"
                 data-datatable-url-value="{{ path('app_program_settings_skill_groups_skills_data', {id: program.id, groupId: skillGroup.id}) }}"
                 data-datatable-edit-url-template-value="{{ path('app_program_settings_skill_groups_skills_edit', {id: program.id, groupId: skillGroup.id, skillId: '__ID__'}) }}"
                 data-datatable-deactivate-url-template-value="{{ path('app_program_settings_skill_groups_skills_deactivate', {id: program.id, groupId: skillGroup.id, skillId: '__ID__'}) }}"
                 data-datatable-deactivate-token-value="{{ csrf_token('program_settings_deactivate') }}"
                 data-datatable-edit-label-value="{{ 'editActionLabel'|trans }}"
                 data-datatable-deactivate-label-value="{{ 'deactivateActionLabel'|trans }}"
                 data-datatable-deactivate-confirm-message-value="{{ 'deactivateConfirmMessage'|trans }}"
                 data-datatable-deactivate-error-message-value="{{ 'deactivateErrorMessage'|trans }}"
                 data-datatable-page-length-value="10"
                 data-datatable-columns-value="{{ [
                     {data: 'label'},
                     {data: null, render: 'actions'},
                 ]|json_encode }}"
                 data-datatable-language-value="{{ {
                     info: 'datatableInfoLabel'|trans,
                     infoEmpty: 'datatableInfoEmptyLabel'|trans,
                     infoFiltered: 'datatableInfoFilteredLabel'|trans,
                     zeroRecords: 'datatableZeroRecordsLabel'|trans,
                     processing: 'datatableProcessingLabel'|trans,
                     lengthMenu: 'datatableLengthMenuLabel'|trans,
                     search: 'datatableSearchLabel'|trans,
                     paginate: {
                         next: 'datatablePaginateNextLabel'|trans,
                         previous: 'datatablePaginatePreviousLabel'|trans,
                     },
                 }|json_encode }}">
                <div class="form-check form-switch mb-2" data-datatable-target="includeInactiveWrapper">
                    <input class="form-check-input" type="checkbox" id="program-skill-group-skills-include-inactive" data-datatable-target="includeInactive" data-action="change->datatable#reload">
                    <label class="form-check-label" for="program-skill-group-skills-include-inactive">{{ 'showInactiveFilterLabel'|trans }}</label>
                </div>
                <div class="table-responsive">
                    <table class="table table-vcenter card-table table-striped" data-datatable-target="table">
                        <thead>
                            <tr>
                                <th>{{ 'skillLabelColumnLabel'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
