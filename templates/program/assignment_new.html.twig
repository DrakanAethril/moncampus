{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editAssignmentPageHeading' : 'newAssignmentPageHeading')|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editAssignmentPageHeading' : 'newAssignmentPageHeading')|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-12">{{ form_row(form.title) }}</div>
                    <div class="col-12">{{ form_row(form.description) }}</div>
                    <div class="col-md-6">{{ form_row(form.dueDate) }}</div>
                </div>
                <div data-controller="assignment-audience" data-action="change->assignment-audience#toggle">
                    {{ form_row(form.audienceType) }}
                    <div data-assignment-audience-target="optionField">
                        {{ form_row(form.options) }}
                    </div>
                    <div class="mb-3" data-assignment-audience-target="recipientsField">
                        <label class="form-label" for="manual_recipients">{{ 'assignmentAudienceManualFieldLabel'|trans }}</label>
                        <select id="manual_recipients" name="manual_recipients[]" multiple class="form-select"
                                data-controller="tom-select"
                                data-tom-select-url-value="{{ path('app_program_assignments_students_search', {id: program.id}) }}"
                                data-tom-select-placeholder-value="{{ 'assignmentAudienceManualSearchPlaceholder'|trans }}">
                            {% if isEdit %}
                                {% for student in form.vars.data.manualRecipients %}
                                    <option value="{{ student.id }}" selected>{{ student.displayName ?? student.username }}</option>
                                {% endfor %}
                            {% endif %}
                        </select>
                    </div>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_program_assignments', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
            {% if isEdit %}
                <form method="post" action="{{ path('app_program_assignments_remove', {id: program.id, assignmentId: form.vars.data.id}) }}" class="mt-3" onsubmit="return confirm('{{ 'removeAssignmentConfirmMessage'|trans|e('js') }}')">
                    <input type="hidden" name="_token" value="{{ csrf_token('program_assignments_remove') }}">
                    <button type="submit" class="btn btn-ghost-danger">{{ 'removeActionLabel'|trans }}</button>
                </form>
            {% endif %}
        </div>
    </div>
{% endblock %}
