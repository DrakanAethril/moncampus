{% extends 'layout/app.html.twig' %}

{% block title %}{{ (isEdit ? 'editAssignmentPageHeading' : 'newAssignmentPageHeading')|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ (isEdit ? 'editAssignmentPageHeading' : 'newAssignmentPageHeading')|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        {{ form_errors(form) }}
                        {{ form_row(form.title) }}
                        {{ form_row(form.description) }}
                        {{ form_row(form.dueDate) }}
                        {{ form_row(form.audienceType) }}
                        {{ form_row(form.option) }}
                        {{ form_row(form.manualRecipients) }}
                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_program_assignments', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                            {{ form_widget(form.submit) }}
                        </div>
                        {{ form_rest(form) }}
                    {{ form_end(form) }}
                    {% if isEdit %}
                        <form method="post" action="{{ path('app_program_assignments_remove', {id: program.id, assignmentId: form.vars.data.id}) }}" class="mt-3" onsubmit="return confirm('{{ 'removeAssignmentConfirmMessage'|trans|e('js') }}')">
                            <input type="hidden" name="_token" value="{{ csrf_token('program_assignments_remove') }}">
                            <button type="submit" class="btn btn-ghost-danger">{{ 'removeActionLabel'|trans }}</button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
