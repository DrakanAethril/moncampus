{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'quizLiveNewPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: 'programQuizNavLabel'|trans, url: path('app_program_quiz', {id: program.id})},
        {label: 'quizLiveNewPageHeading'|trans, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'quizLiveNewPageHeading'|trans }}{% endblock %}

{% block main %}
    <div class="card" style="max-width: 640px;">
        <div class="card-header">
            <h3 class="card-title">{{ 'quizLiveNewPageHeading'|trans }}</h3>
        </div>
        <form method="post" action="{{ path('app_program_quiz_live_create', {id: program.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('quiz_live_create') }}">
            <div class="card-body d-flex flex-column gap-3">
                {% if templates is empty %}
                    <p class="text-secondary mb-0">{{ 'quizLiveNewEmptyTemplatesMessage'|trans }}</p>
                {% else %}
                    <div>
                        <label class="form-label" for="quiz-live-template">{{ 'quizLiveNewTemplateFieldLabel'|trans }}</label>
                        <select class="form-select" id="quiz-live-template" name="templateId" required>
                            {% for template in templates %}
                                <option value="{{ template.id }}">{{ template.name }} · {{ template.questions|length }} {{ 'quizQuestionsCountLabel'|trans }}</option>
                            {% endfor %}
                        </select>
                        <div class="form-hint">{{ 'quizLiveNewTemplateFieldHint'|trans }}</div>
                    </div>
                    <div>
                        <label class="form-label" for="quiz-live-seconds">{{ 'quizLaunchSecondsPerQuestionFieldLabel'|trans }}</label>
                        <input type="number" class="form-control" id="quiz-live-seconds" name="secondsPerQuestion" min="5" max="300" placeholder="20">
                    </div>
                {% endif %}
            </div>
            <div class="card-footer text-end">
                <a href="{{ path('app_program_quiz', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                {% if templates is not empty %}
                    <button type="submit" class="btn btn-warning">{{ 'quizLiveNewSubmitAction'|trans }}</button>
                {% endif %}
            </div>
        </form>
    </div>
{% endblock %}
