{# Expects `user`; `options` (list<Option>) is optional - the caller passes each user's
   assigned Options (see templates/program/students.html.twig and teachers.html.twig, backed by
   ProgramStudentOptionRepository/ProgramTeacherOptionRepository respectively). #}
{% set card_avatar_url = avatar_url(user) %}
<div class="col-md-6 col-lg-3">
    <div class="card">
        <div class="card-body p-4 text-center">
            <span class="avatar avatar-xl mb-3"{% if card_avatar_url %} style="background-image: url({{ card_avatar_url }})"{% endif %}>{% if not card_avatar_url %}{{ (user.displayName ?? user.username)|slice(0, 1)|upper }}{% endif %}</span>
            <h3 class="m-0 mb-1">{{ user.displayName ?? user.username }}</h3>
            <div class="text-secondary">{{ user.username }}</div>

            {% if options is defined and options|length > 0 %}
                <div class="mt-3">
                    {% for option in options %}
                        <span class="badge me-1" style="background-color: {{ option.color }}; color: #fff;">{{ option.shortName }}</span>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
