{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'gradebookPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: program.shortName, url: path('app_program_students', {id: program.id})},
        {label: 'gradebookNavLabel'|trans, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'gradebookPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block main %}
    <div data-controller="evaluation-grid"
         data-evaluation-grid-evaluations-value="{{ evaluationsJson|json_encode }}"
         data-evaluation-grid-roster-value="{{ rosterJson|json_encode }}"
         data-evaluation-grid-grades-value="{{ gradesJson|json_encode(constant('JSON_FORCE_OBJECT')) }}"
         data-evaluation-grid-periods-value="{{ periodsJson|json_encode }}"
         data-evaluation-grid-save-url-template-value="{{ path('app_program_gradebook_save_grade', {id: program.id, evaluationId: '__EVAL_ID__', studentId: '__STUDENT_ID__'}) }}"
         data-evaluation-grid-edit-url-template-value="{{ path('app_program_gradebook_evaluation_edit', {id: program.id, evaluationId: '__EVAL_ID__'}) }}"
         data-evaluation-grid-deactivate-url-template-value="{{ path('app_program_gradebook_evaluation_deactivate', {id: program.id, evaluationId: '__EVAL_ID__'}) }}"
         data-evaluation-grid-detail-url-template-value="{{ path('app_program_gradebook_evaluation_detail', {id: program.id, evaluationId: '__EVAL_ID__'}) }}"
         data-evaluation-grid-csrf-token-value="{{ csrf_token('gradebook_save') }}"
         data-evaluation-grid-labels-value="{{ {
             averageColumnLabel: 'gradebookAverageColumnLabel'|trans,
             editEvaluationTitle: 'gradebookEditEvaluationTitle'|trans,
             deleteEvaluationTitle: 'gradebookDeleteEvaluationTitle'|trans,
             deleteEvaluationConfirmMessage: 'gradebookDeleteEvaluationConfirmMessage'|trans,
             viewDetailTitle: 'gradebookViewDetailTitle'|trans,
             cellPlaceholder: 'gradebookCellPlaceholder'|trans,
             absentShortLabel: 'gradebookAbsentShortLabel'|trans,
             notEvaluatedShortLabel: 'gradebookNotEvaluatedShortLabel'|trans,
             notTestedShortLabel: 'gradebookNotTestedShortLabel'|trans,
             networkErrorMessage: 'gradebookNetworkErrorMessage'|trans,
             audioCommentTitle: 'gradebookAudioCommentTitle'|trans,
         }|json_encode }}">
    <div class="d-flex flex-wrap gap-2 align-items-end mb-3">
        {% if topicsJson|length > 1 %}
            <div>
                <label class="form-label">{{ 'gradebookSubjectFieldLabel'|trans }}</label>
                <select class="form-select" data-action="change->evaluation-grid#navigateTopic">
                    {% for t in topicsJson %}
                        <option value="{{ path('app_program_gradebook', {id: program.id, topic: t.id}) }}" {{ t.id == topic.id ? 'selected' }}>{{ t.name }}</option>
                    {% endfor %}
                </select>
            </div>
        {% endif %}

        {% if periodsJson|length > 0 %}
            <div>
                <label class="form-label">{{ 'gradebookPeriodFieldLabel'|trans }}</label>
                <select class="form-select" data-evaluation-grid-target="periodSelect" data-action="change->evaluation-grid#onFilterChange">
                    <option value="annee">{{ 'gradebookPeriodFullYearLabel'|trans }}</option>
                    {% for p in periodsJson %}
                        <option value="{{ p.id }}">{{ p.name }}</option>
                    {% endfor %}
                </select>
            </div>
        {% endif %}

        <div>
            <label class="form-label">{{ 'evaluationTypeFieldLabel'|trans }}</label>
            <select class="form-select" data-evaluation-grid-target="typeSelect" data-action="change->evaluation-grid#onFilterChange">
                <option value="all">{{ 'gradebookAllTypesLabel'|trans }}</option>
                <option value="written">{{ 'evaluationTypeWrittenLabel'|trans }}</option>
                <option value="oral">{{ 'evaluationTypeOralLabel'|trans }}</option>
                <option value="practical">{{ 'evaluationTypePracticalLabel'|trans }}</option>
            </select>
        </div>

        <div>
            <label class="form-label">{{ 'evaluationModalityFieldLabel'|trans }}</label>
            <select class="form-select" data-evaluation-grid-target="modalitySelect" data-action="change->evaluation-grid#onFilterChange">
                <option value="all">{{ 'gradebookAllModalitiesLabel'|trans }}</option>
                <option value="individual">{{ 'evaluationModalityIndividualLabel'|trans }}</option>
                <option value="group">{{ 'evaluationModalityGroupLabel'|trans }}</option>
            </select>
        </div>

        <div>
            <label class="form-label">{{ 'evaluationStatusFieldLabel'|trans }}</label>
            <select class="form-select" data-evaluation-grid-target="statusSelect" data-action="change->evaluation-grid#onFilterChange">
                <option value="all">{{ 'gradebookAllStatusesLabel'|trans }}</option>
                <option value="planned">{{ 'evaluationStatusPlannedLabel'|trans }}</option>
                <option value="surprise">{{ 'evaluationStatusSurpriseLabel'|trans }}</option>
            </select>
        </div>

        <a href="{{ path('app_program_gradebook_evaluation_new', {id: program.id, topic: topic.id}) }}" class="btn btn-primary ms-auto">
            {{ 'gradebookNewEvaluationButtonLabel'|trans }}
        </a>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-vcenter card-table table-striped">
                <thead data-evaluation-grid-target="thead"></thead>
                <tbody data-evaluation-grid-target="tbody"></tbody>
            </table>
        </div>
    </div>
    </div>

    <div class="modal-backdrop-custom" style="position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 1050; display: flex; align-items: center; justify-content: center;"
         data-controller="grade-audio-comment"
         data-grade-audio-comment-request-upload-url-template-value="{{ path('app_program_gradebook_audio_request_upload', {id: program.id, evaluationId: '__EVAL_ID__', studentId: '__STUDENT_ID__'}) }}"
         data-grade-audio-comment-confirm-url-template-value="{{ path('app_program_gradebook_audio_confirm', {id: program.id, evaluationId: '__EVAL_ID__', studentId: '__STUDENT_ID__'}) }}"
         data-grade-audio-comment-delete-url-template-value="{{ path('app_program_gradebook_audio_delete', {id: program.id, evaluationId: '__EVAL_ID__', studentId: '__STUDENT_ID__'}) }}"
         data-grade-audio-comment-csrf-token-value="{{ csrf_token('gradebook_save') }}"
         data-grade-audio-comment-labels-value="{{ {
             micDeniedMessage: 'gradebookAudioMicDeniedMessage'|trans,
             recordingMessage: 'gradebookAudioRecordingMessage'|trans,
             uploadingMessage: 'gradebookAudioUploadingMessage'|trans,
             networkErrorMessage: 'gradebookNetworkErrorMessage'|trans,
             deleteConfirmMessage: 'gradebookAudioDeleteConfirmMessage'|trans,
         }|json_encode }}"
         data-grade-audio-comment-target="backdrop" hidden>
        <div class="card" style="width: 420px">
            <div class="card-body">
                <h3 class="card-title" data-grade-audio-comment-target="studentName"></h3>
                <div class="d-flex gap-2 mb-3">
                    <button type="button" class="btn btn-outline-danger" data-grade-audio-comment-target="recordBtn" data-action="click->grade-audio-comment#startRecording">
                        ● {{ 'gradebookAudioRecordButtonLabel'|trans }}
                    </button>
                    <button type="button" class="btn btn-outline-secondary" data-grade-audio-comment-target="stopBtn" data-action="click->grade-audio-comment#stopRecording" disabled>
                        {{ 'gradebookAudioStopButtonLabel'|trans }}
                    </button>
                </div>
                <audio controls class="w-100 mb-2" data-grade-audio-comment-target="preview" hidden></audio>
                <div class="text-secondary small mb-3" data-grade-audio-comment-target="status"></div>
                <div class="d-flex justify-content-between">
                    <div>
                        <button type="button" class="btn btn-link" data-action="click->grade-audio-comment#close">{{ 'cancelAction'|trans }}</button>
                        <button type="button" class="btn btn-outline-danger" data-grade-audio-comment-target="deleteBtn" data-action="click->grade-audio-comment#deleteAudio" hidden>{{ 'deactivateActionLabel'|trans }}</button>
                    </div>
                    <button type="button" class="btn btn-primary" data-grade-audio-comment-target="saveBtn" data-action="click->grade-audio-comment#save" disabled>{{ 'submitSaveAction'|trans }}</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
