{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'internshipTeamEvaluationsPageHeading'|trans }} - {{ tutorLink.student.displayName }}{% endblock %}
{% block page_title %}{{ 'internshipTeamEvaluationsPageHeading'|trans }} - {{ tutorLink.student.displayName }}{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_program_internship_tutors', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
{% endblock %}

{% block main %}
    <div class="card">
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                    <tr>
                        <th>{{ 'internshipTutorHomePeriodColumnLabel'|trans }}</th>
                        <th>{{ 'internshipTutorHomeStatusColumnLabel'|trans }}</th>
                        <th class="cm-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in rows %}
                        <tr>
                            <td>{{ entry.period.name }}</td>
                            <td>
                                {% if entry.submitted %}
                                    <span class="badge bg-green-lt">{{ 'internshipEvaluationSubmittedLabel'|trans }}</span>
                                {% else %}
                                    <span class="badge bg-secondary-lt">{{ 'internshipEvaluationNotSubmittedLabel'|trans }}</span>
                                {% endif %}
                            </td>
                            <td class="cm-actions">
                                <a href="{{ path('app_program_internship_tutors_team_evaluation', {id: program.id, tutorLinkId: tutorLink.id, periodId: entry.period.id}) }}" class="{{ entry.submitted ? 'cm-action--warning' : 'cm-action--positive' }}">
                                    {{ (entry.submitted ? 'editActionLabel' : 'internshipEvaluateButtonLabel')|trans }}
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-secondary">{{ 'internshipTutorHomeNoPeriodsLabel'|trans }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
