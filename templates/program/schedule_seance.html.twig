{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'scheduleSeanceAction'|trans }} - {{ seanceInstance.titre }}{% endblock %}
{% block page_title %}{{ 'scheduleSeanceAction'|trans }} - {{ seanceInstance.titre }}{% endblock %}

{% block main %}
    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row">
                    <div class="col-md-6">{{ form_row(form.day) }}</div>
                    <div class="col-md-6">{{ form_row(form.classRoom) }}</div>
                    <div class="col-md-6">{{ form_row(form.startHour) }}</div>
                    <div class="col-md-6">{{ form_row(form.endHour) }}</div>
                    <div class="col-md-6">
                        <label class="form-label" for="teacher">{{ 'lessonSessionTeacherFieldLabel'|trans }}</label>
                        <select id="teacher" name="teacher" class="form-select"
                                data-controller="tom-select"
                                data-tom-select-url-value="{{ path('app_program_sequence_teachers_search', {id: program.id}) }}"
                                data-tom-select-placeholder-value="{{ 'lessonSessionTeacherFieldLabel'|trans }}"></select>
                    </div>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ seanceInstance.sequenceInstance ? path('app_program_sequences_show', {id: program.id, sequenceInstanceId: seanceInstance.sequenceInstance.id}) : path('app_program_sequences', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
                    {{ form_widget(form.submit) }}
                </div>
                {{ form_rest(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
