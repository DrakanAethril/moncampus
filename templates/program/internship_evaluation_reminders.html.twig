{% extends 'layout/app.html.twig' %}

{% block title %}{{ 'internshipEvaluationRemindersPageHeading'|trans }} - {{ program.shortName }}{% endblock %}
{% block page_title %}{{ 'internshipEvaluationRemindersPageHeading'|trans }} - {{ program.shortName }}{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_program_internship_tutors', {id: program.id}) }}" class="btn btn-link">{{ 'cancelAction'|trans }}</a>
{% endblock %}

{% block main %}
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" action="{{ path('app_program_internship_tutors_reminders', {id: program.id}) }}" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label" for="period">{{ 'internshipEvaluationReminderPeriodFieldLabel'|trans }}</label>
                    <select id="period" name="period" class="form-select" onchange="this.form.requestSubmit()">
                        <option value="">{{ 'internshipEvaluationReminderPeriodPlaceholder'|trans }}</option>
                        {% for period in periods %}
                            <option value="{{ period.id }}" {{ selectedPeriod and selectedPeriod.id == period.id ? 'selected' }}>{{ period.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-outline-primary">{{ 'internshipEvaluationReminderShowAction'|trans }}</button>
                </div>
            </form>
        </div>
    </div>

    {% if selectedPeriod %}
        {% set totalPending = pendingStudents|length + pendingTutorLinks|length %}
        <div class="card">
            <div class="card-header d-flex align-items-center">
                <h3 class="card-title mb-0">{{ 'internshipEvaluationReminderPendingCountLabel'|trans({'%count%': totalPending}) }}</h3>
                {% if totalPending > 0 %}
                    <form method="post" action="{{ path('app_program_internship_tutors_reminders_send', {id: program.id}) }}" class="ms-auto" onsubmit="return confirm('{{ 'internshipEvaluationReminderConfirmMessage'|trans|e('js') }}')">
                        <input type="hidden" name="period" value="{{ selectedPeriod.id }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('program_internship_reminders_send') }}">
                        <button type="submit" class="btn btn-primary">{{ 'internshipEvaluationReminderSendAction'|trans }}</button>
                    </form>
                {% endif %}
            </div>
            <div class="card-body">
                <h4>{{ 'internshipEvaluationReminderStudentsHeading'|trans }}</h4>
                {% if pendingStudents is empty %}
                    <p class="text-secondary">{{ 'internshipEvaluationReminderNoneLabel'|trans }}</p>
                {% else %}
                    <ul class="mb-4">
                        {% for student in pendingStudents %}
                            <li>{{ student.displayName ?? student.username }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}

                <h4>{{ 'internshipEvaluationReminderTutorsHeading'|trans }}</h4>
                {% if pendingTutorLinks is empty %}
                    <p class="text-secondary">{{ 'internshipEvaluationReminderNoneLabel'|trans }}</p>
                {% else %}
                    <ul class="mb-0">
                        {% for tutorLink in pendingTutorLinks %}
                            <li>{{ tutorLink.tutorFirstName }} {{ tutorLink.tutorLastName }} ({{ tutorLink.student.displayName ?? tutorLink.student.username }})</li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    {% endif %}
{% endblock %}
