{{ form_start(form) }}
    {{ form_errors(form) }}
    {{ form_row(form.legalName) }}
    {{ form_widget(form.submit) }}
    {{ form_rest(form) }}
{{ form_end(form) }}

{% if program.options is not empty %}
    <div class="card mt-3">
        <div class="card-header">
            <h3 class="card-title">{{ 'internshipOptionLegalNamesSectionTitle'|trans }}</h3>
        </div>
        <form method="post" action="{{ path('app_program_internship_denomination_options', {id: program.id}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('program_internship_legal_names') }}">
            <div class="card-body">
                <p class="text-secondary">{{ 'internshipOptionLegalNamesHelpText'|trans }}</p>
                {% for option in program.options %}
                    <div class="mb-3">
                        <label class="form-label">{{ option.name }}</label>
                        <input type="text" class="form-control" name="legalNames[{{ option.id }}]" placeholder="{{ form.legalName.vars.value ?: program.name }}" value="{{ legalNamesByOptionId[option.id] ?? '' }}">
                    </div>
                {% endfor %}
            </div>
            <div class="card-footer text-end">
                <button type="submit" class="btn btn-primary">{{ 'submitCreateAction'|trans }}</button>
            </div>
        </form>
    </div>
{% endif %}
