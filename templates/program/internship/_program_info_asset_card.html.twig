{# Expects (passed with `only` by the includer): programId, titleKey, fileKey, uploadForm,
   uploadRoute, deleteRoute - see templates/program/internship/_info_content.html.twig #}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">{{ titleKey|trans }}</h3>
    </div>
    <div class="card-body">
        {% if fileKey %}
            {% if fileKey ends with '.pdf' %}
                <p class="mb-3">
                    <a href="{{ file_url(fileKey) }}" target="_blank" class="btn btn-outline-secondary btn-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M14 3v4a1 1 0 0 0 1 1h4" /><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z" /></svg>
                        {{ 'internshipBookletDownloadPdfButtonLabel'|trans }}
                    </a>
                </p>
            {% else %}
                <img src="{{ file_url(fileKey) }}" class="img-fluid mb-3" style="max-height: 200px;" alt="">
            {% endif %}
            <form method="post" action="{{ path(deleteRoute, {id: programId}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('program_internship_info_delete') }}">
                <button type="submit" class="btn btn-outline-danger btn-sm">{{ 'programInfoRemoveAction'|trans }}</button>
            </form>
        {% endif %}
    </div>
    <div class="card-footer">
        {{ form_start(uploadForm, {action: path(uploadRoute, {id: programId})}) }}
            {{ form_errors(uploadForm) }}
            {{ form_row(uploadForm.file) }}
            {{ form_widget(uploadForm.submit, {attr: {class: 'btn btn-primary btn-sm'}}) }}
            {{ form_rest(uploadForm) }}
        {{ form_end(uploadForm) }}
    </div>
</div>
