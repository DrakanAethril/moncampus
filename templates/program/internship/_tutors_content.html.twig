<div data-frankenphp-hot-reload-preserve
     data-controller="datatable"
     data-datatable-url-value="{{ path('app_program_internship_tutors_data', {id: program.id}) }}"
     data-datatable-edit-url-template-value="{{ path('app_program_internship_tutors_edit', {id: program.id, tutorLinkId: '__ID__'}) }}"
     data-datatable-deactivate-url-template-value="{{ path('app_program_internship_tutors_deactivate', {id: program.id, tutorLinkId: '__ID__'}) }}"
     data-datatable-deactivate-token-value="{{ csrf_token('program_internship_deactivate') }}"
     data-datatable-print-url-template-value="{{ path('app_program_internship_tutors_booklet', {id: program.id, tutorLinkId: '__ID__'}) }}"
     data-datatable-print-label-value="{{ 'internshipBookletViewButtonLabel'|trans }}"
     data-datatable-edit-label-value="{{ 'editActionLabel'|trans }}"
     data-datatable-deactivate-label-value="{{ 'deactivateActionLabel'|trans }}"
     data-datatable-deactivate-confirm-message-value="{{ 'deactivateConfirmMessage'|trans }}"
     data-datatable-deactivate-error-message-value="{{ 'deactivateErrorMessage'|trans }}"
     data-datatable-page-length-value="10"
     data-datatable-columns-value="{{ [
         {data: 'studentName', render: 'html'},
         {data: 'tutorName'},
         {data: 'companyName'},
         {data: 'contractStartDate'},
         {data: 'contractEndDate'},
         {data: null, render: 'reportActions'},
     ]|json_encode }}"
     data-datatable-language-value="{{ {
         info: 'datatableInfoLabel'|trans,
         infoEmpty: 'datatableInfoEmptyLabel'|trans,
         infoFiltered: 'datatableInfoFilteredLabel'|trans,
         zeroRecords: 'datatableZeroRecordsLabel'|trans,
         processing: 'datatableProcessingLabel'|trans,
         lengthMenu: 'datatableLengthMenuLabel'|trans,
         search: 'datatableSearchLabel'|trans,
         paginate: {
             next: 'datatablePaginateNextLabel'|trans,
             previous: 'datatablePaginatePreviousLabel'|trans,
         },
     }|json_encode }}">
    <div class="form-check form-switch mb-2" data-datatable-target="includeInactiveWrapper">
        <input class="form-check-input" type="checkbox" id="internship-tutors-include-inactive" data-datatable-target="includeInactive" data-action="change->datatable#reload">
        <label class="form-check-label" for="internship-tutors-include-inactive">{{ 'showInactiveFilterLabel'|trans }}</label>
    </div>
    <div class="table-responsive">
        <table class="table table-vcenter card-table table-striped" data-datatable-target="table">
            <thead>
                <tr>
                    <th>{{ 'internshipTutorLinkStudentColumnLabel'|trans }}</th>
                    <th>{{ 'internshipTutorLinkTutorColumnLabel'|trans }}</th>
                    <th>{{ 'internshipTutorLinkCompanyNameColumnLabel'|trans }}</th>
                    <th>{{ 'internshipTutorLinkContractStartDateColumnLabel'|trans }}</th>
                    <th>{{ 'internshipTutorLinkContractEndDateColumnLabel'|trans }}</th>
                    <th class="w-1"></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
