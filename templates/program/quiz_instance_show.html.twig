{% extends 'layout/app.html.twig' %}

{% block title %}{{ quizInstance.name }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: 'programQuizNavLabel'|trans, url: path('app_program_quiz', {id: program.id})},
        {label: program.shortName, url: path('app_program_quiz', {id: program.id})},
        {label: quizInstance.name, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ quizInstance.name }}{% endblock %}

{% block main %}
    <div class="cm-note mb-3">
        <span class="cm-note__icon">i</span>
        <div>{{ 'quizInstanceFrozenNoteText'|trans }}</div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-5">
            <div class="card">
                <div class="card-body d-flex flex-column gap-3">
                    <div class="cm-subhead">
                        <div class="cm-subhead__title">{{ 'quizInstanceSettingsTitle'|trans }}</div>
                    </div>
                    <div class="cm-optionrow">
                        <div class="cm-optionrow__name">{{ 'quizLaunchModeFieldLabel'|trans }}</div>
                        <span class="badge {{ quizInstance.mode.value == 'evaluation' ? 'bg-blue-lt' : 'bg-green-lt' }}">{{ quizInstance.mode.labelKey|trans }}</span>
                    </div>
                    <div class="cm-optionrow">
                        <div class="cm-optionrow__name">{{ 'programQuizWindowColumnLabel'|trans }}</div>
                        <div>{{ quizInstance.opensAt ? quizInstance.opensAt|date('d/m/Y H:i') : '—' }} → {{ quizInstance.closesAt ? quizInstance.closesAt|date('d/m/Y H:i') : '—' }}</div>
                    </div>
                    <div class="cm-optionrow">
                        <div class="cm-optionrow__name">{{ 'quizLaunchScoringFieldLabel'|trans }}</div>
                        <div>{{ quizInstance.scoring.labelKey|trans }}</div>
                    </div>
                    <div class="cm-optionrow">
                        <div class="cm-optionrow__name">{{ 'quizLaunchScoreVisibleImmediatelyFieldLabel'|trans }}</div>
                        <div>{{ (quizInstance.scoreVisibleImmediately ? 'yesLabel' : 'noLabel')|trans }}</div>
                    </div>
                    <div class="cm-optionrow">
                        <div class="cm-optionrow__name">{{ 'quizLaunchSecondsPerQuestionFieldLabel'|trans }}</div>
                        <div>{{ quizInstance.secondsPerQuestion ?? '—' }}</div>
                    </div>
                    <div class="cm-optionrow">
                        <div class="cm-optionrow__name">{{ 'quizLaunchGlobalTimeMinutesFieldLabel'|trans }}</div>
                        <div>{{ quizInstance.globalTimeMinutes ?? '—' }}</div>
                    </div>

                    <div class="cm-subhead">
                        <div class="cm-subhead__title">{{ 'quizLaunchDifficultySliderLabel'|trans }}</div>
                    </div>
                    <div class="cm-diffbar">
                        <span class="cm-diffbar__facile" style="width: {{ quizInstance.difficultyFacilePercent }}%"></span>
                        <span class="cm-diffbar__moyen" style="width: {{ quizInstance.difficultyMoyenPercent }}%"></span>
                        <span class="cm-diffbar__difficile" style="width: {{ quizInstance.difficultyDifficilePercent }}%"></span>
                    </div>
                    <div class="cm-difflegend">
                        <span class="cm-difflegend__item"><span class="cm-difflegend__swatch" style="background: var(--cm-positive-tx);"></span>{{ 'questionDifficultyFacileLabel'|trans }} {{ quizInstance.difficultyFacilePercent }}% ({{ quizInstance.difficultyFacileCount }} q.)</span>
                        <span class="cm-difflegend__item"><span class="cm-difflegend__swatch" style="background: var(--cm-gold);"></span>{{ 'questionDifficultyMoyenLabel'|trans }} {{ quizInstance.difficultyMoyenPercent }}% ({{ quizInstance.difficultyMoyenCount }} q.)</span>
                        <span class="cm-difflegend__item"><span class="cm-difflegend__swatch" style="background: var(--cm-red-tx);"></span>{{ 'questionDifficultyDifficileLabel'|trans }} {{ quizInstance.difficultyDifficilePercent }}% ({{ quizInstance.difficultyDifficileCount }} q.)</span>
                    </div>

                    <div class="cm-subhead">
                        <div class="cm-subhead__title">{{ 'quizLaunchQuestionSelectionTitle'|trans }}</div>
                    </div>
                    <div class="cm-optionrow">
                        <div class="cm-optionrow__name">{{ 'quizTemplateDefaultQuestionCountFieldLabel'|trans }}</div>
                        <div>{{ quizInstance.questionCount }} / {{ quizInstance.questions|length }}</div>
                    </div>
                    <div class="cm-optionrow">
                        <div class="cm-optionrow__name">{{ 'quizLaunchSameQuestionsForAllFieldLabel'|trans }}</div>
                        <div>{{ (quizInstance.sameQuestionsForAll ? 'yesLabel' : 'noLabel')|trans }}</div>
                    </div>
                    <div class="cm-optionrow">
                        <div class="cm-optionrow__name">{{ 'quizLaunchQuestionOrderPerStudentFieldLabel'|trans }}</div>
                        <div>{{ (quizInstance.questionOrderPerStudent ? 'yesLabel' : 'noLabel')|trans }}</div>
                    </div>
                    <div class="cm-optionrow">
                        <div class="cm-optionrow__name">{{ 'quizLaunchAnswerOrderPerStudentFieldLabel'|trans }}</div>
                        <div>{{ (quizInstance.answerOrderPerStudent ? 'yesLabel' : 'noLabel')|trans }}</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-7">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">{{ quizInstance.questions|length }} {{ 'quizQuestionsCountLabel'|trans }}</h3>
                </div>
                <div class="cm-qbank" style="border: 0; border-radius: 0;">
                    {% for question in quizInstance.questions %}
                        <div class="cm-qbank__row">
                            <span class="cm-qbank__index">{{ loop.index }}</span>
                            <span class="badge bg-blue-lt">{{ question.type.shortLabelKey|trans }}</span>
                            <span class="cm-qbank__label">{{ question.label }}</span>
                            <span class="cm-qbank__dots cm-diffdots">
                                {% for i in 1..3 %}<span class="{{ i <= question.effectiveDifficulty.dotCount ? 'is-filled' }}"></span>{% endfor %}
                            </span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
