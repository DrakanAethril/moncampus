{% extends 'layout/app.html.twig' %}

{% block title %}{{ quizInstance.name }}{% endblock %}

{% block page_breadcrumb %}
    {% include '_breadcrumb.html.twig' with {segments: [
        {label: 'homeNavLabel'|trans, url: path('app_home')},
        {label: 'programQuizNavLabel'|trans, url: path('app_program_quiz', {id: program.id})},
        {label: program.shortName, url: path('app_program_quiz', {id: program.id})},
        {label: 'programQuizResultsBreadcrumbLabel'|trans, url: app.request.requestUri},
    ]} %}
{% endblock %}
{% block page_title %}{{ 'programQuizResultsHeadingTemplate'|trans({'%name%': quizInstance.name}) }}{% endblock %}

{% block main %}
    <div class="row g-3 mb-3">
        <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body py-3">
                <div class="text-secondary text-uppercase small fw-bold" style="letter-spacing:.5px;">{{ 'programQuizKpiParticipationLabel'|trans }}</div>
                <div style="font: 600 22px var(--cm-font-title); color: var(--cm-ink); margin-top: 2px;">{{ kpis.participation }}</div>
            </div></div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body py-3">
                <div class="text-secondary text-uppercase small fw-bold" style="letter-spacing:.5px;">{{ 'programQuizKpiAverageLabel'|trans }}</div>
                <div style="font: 600 22px var(--cm-font-title); color: var(--cm-ink); margin-top: 2px;">{{ kpis.average20 is not null ? kpis.average20 ~ '/20' : '—' }}</div>
            </div></div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body py-3">
                <div class="text-secondary text-uppercase small fw-bold" style="letter-spacing:.5px;">{{ 'programQuizKpiSuccessRateLabel'|trans }}</div>
                <div style="font: 600 22px var(--cm-font-title); color: var(--cm-ink); margin-top: 2px;">{{ kpis.successRate is not null ? kpis.successRate ~ ' %' : '—' }}</div>
            </div></div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card"><div class="card-body py-3">
                <div class="text-secondary text-uppercase small fw-bold" style="letter-spacing:.5px;">{{ 'programQuizKpiAverageTimeLabel'|trans }}</div>
                <div style="font: 600 22px var(--cm-font-title); color: var(--cm-ink); margin-top: 2px;">{{ kpis.averageSeconds is not null ? (kpis.averageSeconds // 60) ~ ' min ' ~ (kpis.averageSeconds % 60) ~ ' s' : '—' }}</div>
            </div></div>
        </div>
    </div>

    {% include '_tabs.html.twig' with {
        tabs: [
            {url: path('app_program_quiz_show', {id: program.id, instanceId: quizInstance.id, tab: 'student'}), label: 'programQuizTabStudentLabel'|trans, active: tab == 'student'},
            {url: path('app_program_quiz_show', {id: program.id, instanceId: quizInstance.id, tab: 'question'}), label: 'programQuizTabQuestionLabel'|trans, active: tab == 'question'},
        ],
        tabs_action: 'program/_quiz_results_sort_select.html.twig',
    } %}
    <div class="card cm-card--tabbed">
        {% if tab == 'student' %}
            <div class="table-responsive">
                <table class="table table-vcenter card-table">
                    <thead>
                        <tr>
                            <th>{{ 'programQuizStudentColumnLabel'|trans }}</th>
                            <th>{{ 'programQuizAttemptsColumnLabel'|trans }}</th>
                            <th>{{ 'programQuizScoreColumnLabel'|trans }}</th>
                            <th>{{ 'programQuizNote20ColumnLabel'|trans }}</th>
                            <th>{{ 'programQuizDurationColumnLabel'|trans }}</th>
                            <th>{{ 'programQuizStatusColumnLabel'|trans }}</th>
                            <th class="cm-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in studentRows %}
                            <tr>
                                <td class="fw-bold">{{ row.student.displayName ?? row.student.username }}</td>
                                <td class="text-secondary">
                                    {{ row.attemptCount }}
                                    {% if row.hasRelance %}<span class="small">({{ 'programQuizRelaunchedSuffixLabel'|trans }})</span>{% endif %}
                                </td>
                                {% if row.inProgress %}
                                    {# A fresh (possibly relaunched) attempt is running right now - takes priority
                                       over any earlier concluded one, so a teacher who just relaunched a student
                                       immediately sees it reflected here instead of the stale old TERMINÉ score. #}
                                    <td class="text-secondary" colspan="3">—</td>
                                    <td><span class="badge bg-blue-lt">{{ 'programQuizInProgressStatusLabel'|trans }}</span></td>
                                    <td class="cm-actions">
                                        {% if row.retained %}
                                            {% if row.attemptCount > 1 %}
                                                <a href="{{ path('app_program_quiz_student_attempts', {id: program.id, instanceId: quizInstance.id, studentId: row.student.id}) }}" class="cm-action--neutral">{{ 'programQuizViewAttemptsAction'|trans }}</a>
                                            {% else %}
                                                <a href="{{ path('app_program_quiz_attempt_show', {id: program.id, instanceId: quizInstance.id, attemptId: row.retained.id}) }}" class="cm-action--neutral">{{ 'programQuizViewStudentCopyAction'|trans }}</a>
                                            {% endif %}
                                        {% endif %}
                                    </td>
                                {% elseif row.retained %}
                                    <td class="{{ row.retained.scorePercent >= 70 ? 'text-success' : (row.retained.scorePercent >= 40 ? 'text-warning' : 'text-danger') }} fw-bold">{{ row.retained.correctCount }}/{{ row.retained.questionTotal }} · {{ row.retained.scorePercent }} %</td>
                                    <td class="fw-bold">{{ row.retained.scoreOn20 }}</td>
                                    <td class="text-secondary">{{ ((row.retained.submittedAt.timestamp - row.retained.startedAt.timestamp) // 60) }} min {{ ((row.retained.submittedAt.timestamp - row.retained.startedAt.timestamp) % 60) }}</td>
                                    <td><span class="badge {{ row.retained.status.value == 'termine' ? 'bg-green-lt' : 'bg-red-lt' }}">{{ row.retained.status.labelKey|trans|upper }}</span></td>
                                    <td class="cm-actions">
                                        {% if row.attemptCount > 1 %}
                                            <a href="{{ path('app_program_quiz_student_attempts', {id: program.id, instanceId: quizInstance.id, studentId: row.student.id}) }}" class="cm-action--neutral">{{ 'programQuizViewAttemptsAction'|trans }}</a>
                                        {% else %}
                                            <a href="{{ path('app_program_quiz_attempt_show', {id: program.id, instanceId: quizInstance.id, attemptId: row.retained.id}) }}" class="cm-action--neutral">{{ 'programQuizViewStudentCopyAction'|trans }}</a>
                                        {% endif %}
                                    </td>
                                {% else %}
                                    <td class="text-secondary" colspan="3">—</td>
                                    <td><span class="badge bg-red-lt">{{ 'programQuizNotStartedStatusLabel'|trans }}</span></td>
                                    <td class="cm-actions">
                                        <form method="post" action="{{ path('app_program_quiz_relaunch', {id: program.id, instanceId: quizInstance.id, studentId: row.student.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('quiz_relaunch') }}">
                                            <button type="submit" class="cm-action--positive" style="background:none;border:0;padding:0;">{{ 'programQuizRelaunchAction'|trans }}</button>
                                        </form>
                                    </td>
                                {% endif %}
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-secondary">{{ 'programQuizEmptyMessage'|trans }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="7" class="text-secondary small">{{ 'programQuizResultsFooterHintText'|trans }}</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        {% else %}
            <div class="card-body d-flex flex-column gap-3">
                <div class="d-flex flex-column gap-2">
                    {% for row in questionRows %}
                        <div class="row g-2 align-items-center" style="font-size: 13.5px;">
                            <div class="col-auto text-secondary" style="font: 600 12px ui-monospace, monospace; width: 26px;">{{ row.number }}</div>
                            <div class="col-4" style="color: var(--cm-ink);">
                                {{ row.question.label }}
                                {% if row.isTrap %}<span class="badge bg-red-lt ms-1">{{ 'programQuizTrapQuestionBadgeLabel'|trans }}</span>{% endif %}
                            </div>
                            <div class="col-1 text-secondary">{{ row.question.type.shortLabelKey|trans }}</div>
                            <div class="col">
                                <div style="height: 12px; background: var(--cm-border-soft); border-radius: 6px; overflow: hidden;">
                                    <div style="height: 100%; border-radius: 6px; width: {{ row.successRate ?? 0 }}%; background: {{ row.successRate is null ? 'var(--cm-border)' : (row.successRate >= 70 ? 'var(--cm-positive-tx)' : (row.successRate >= 40 ? 'var(--cm-gold)' : 'var(--cm-red-tx)')) }};"></div>
                                </div>
                            </div>
                            <div class="col-auto text-end fw-bold" style="width: 50px; color: {{ row.successRate is null ? 'var(--cm-faint)' : (row.successRate >= 70 ? 'var(--cm-positive-tx)' : (row.successRate >= 40 ? 'var(--cm-warn-tx)' : 'var(--cm-red-tx)')) }};">{{ row.successRate is null ? '—' : row.successRate }}</div>
                        </div>
                    {% else %}
                        <div class="text-secondary">{{ 'programQuizEmptyMessage'|trans }}</div>
                    {% endfor %}
                </div>
                <div class="text-secondary small border-top pt-2">{{ 'programQuizQuestionResultsFooterHintText'|trans }}</div>
            </div>
        {% endif %}
    </div>
{% endblock %}
