{% extends 'base.html.twig' %}

{% block body %}
    <div class="page">
        {% set current_route = app.request.attributes.get('_route') %}
        <header class="navbar navbar-expand-md d-print-none">
            <div class="container-xl">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-menu" aria-controls="navbar-menu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <h1 class="navbar-brand navbar-brand-autodark d-none-navbar-horizontal pe-0 pe-md-3">
                    <a href="{{ path('app_home') }}" class="d-flex align-items-center gap-2">
                        <img src="{{ asset('images/favicon-32x32.png') }}" alt="" width="32" height="32">
                        <span>Institution Beaupeyrat</span>
                    </a>
                </h1>
                <div class="navbar-nav flex-row order-md-last">
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link d-flex lh-1 text-reset p-0" data-bs-toggle="dropdown" aria-label="{{ 'openUserMenuLabel'|trans }}">
                            <span class="avatar avatar-sm">{{ (app.user.displayName ?? app.user.username)|slice(0, 1)|upper }}</span>
                            <div class="d-none d-xl-block ps-2">
                                <div>{{ app.user.displayName ?? app.user.username }}</div>
                                <div class="mt-1 small text-secondary">{{ app.user.username }}</div>
                            </div>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                            <a href="{{ path('app_profile') }}" class="dropdown-item">{{ 'profileNavLabel'|trans }}</a>
                            <a href="{{ path('app_logout') }}" class="dropdown-item">{{ 'logoutAction'|trans }}</a>
                        </div>
                    </div>
                </div>
                <div class="collapse navbar-collapse" id="navbar-menu">
                    <ul class="navbar-nav">
                        <li class="nav-item {{ current_route == 'app_home' ? 'active' }}">
                            <a class="nav-link" href="{{ path('app_home') }}">
                                <span class="nav-link-icon d-md-none d-lg-inline-block">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l-2 0l9 -9l9 9l-2 0" /><path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-7" /><path d="M9 21v-6a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v6" /></svg>
                                </span>
                                <span class="nav-link-title">{{ 'homeNavLabel'|trans }}</span>
                            </a>
                        </li>
                        {% for section in structure_nav_sections() %}
                            {% if is_structure_node_visible(section) %}
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#nav-section-{{ section.id }}" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                        <span class="nav-link-title">{{ section.name }}</span>
                                    </a>
                                    <div class="dropdown-menu">
                                        {% for group in structure_nav_school_year_groups(section) %}
                                            <h6 class="dropdown-header">{{ group.schoolYear.startDate|date('Y') }} - {{ group.schoolYear.endDate|date('Y') }}</h6>
                                            {% for program in group.programs %}
                                                <div class="dropend">
                                                    <a class="dropdown-item dropdown-toggle" href="#nav-program-{{ program.id }}" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                                        {{ program.shortName }}
                                                    </a>
                                                    <div class="dropdown-menu">
                                                        <a class="dropdown-item {{ current_route == 'app_program_students' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_students', {id: program.id}) }}">{{ 'programStudentsNavLabel'|trans }}</a>
                                                        <a class="dropdown-item {{ current_route == 'app_program_teachers' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_teachers', {id: program.id}) }}">{{ 'programTeachersNavLabel'|trans }}</a>
                                                        <a class="dropdown-item {{ current_route == 'app_program_timetable' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_timetable', {id: program.id}) }}">{{ 'programTimetableNavLabel'|trans }}</a>
                                                        {% if is_staff() %}
                                                            <a class="dropdown-item {{ current_route == 'app_program_reporting' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_reporting', {id: program.id}) }}">{{ 'programReportingNavLabel'|trans }}</a>
                                                            <a class="dropdown-item {{ current_route == 'app_program_settings' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_settings', {id: program.id}) }}">{{ 'programSettingsNavLabel'|trans }}</a>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        {% endfor %}
                                    </div>
                                </li>
                            {% endif %}
                        {% endfor %}
                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') or is_granted('ROLE_STAFF-LEAD') %}
                            <li class="nav-item dropdown {{ current_route starts with 'app_settings_' or current_route starts with 'app_directory_' ? 'active' }}">
                                <a class="nav-link dropdown-toggle" href="#navbar-settings" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                    <span class="nav-link-icon d-md-none d-lg-inline-block">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.572 1.065c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.065 -2.572c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37c1 .608 2.296 .07 2.572 -1.065z" /><path d="M9 12a3 3 0 1 0 6 0a3 3 0 0 0 -6 0" /></svg>
                                    </span>
                                    <span class="nav-link-title">{{ 'settingsNavLabel'|trans }}</span>
                                </a>
                                <div class="dropdown-menu">
                                    <div class="dropend">
                                        <a class="dropdown-item dropdown-toggle {{ current_route starts with 'app_directory_' ? 'active' }}" href="#settings-directory" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                            {{ 'directoryNavLabel'|trans }}
                                        </a>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item" href="{{ path('app_directory_groups') }}">{{ 'directoryGroupsNavLabel'|trans }}</a>
                                            <a class="dropdown-item" href="{{ path('app_directory_users') }}">{{ 'directoryUsersNavLabel'|trans }}</a>
                                            <a class="dropdown-item" href="{{ path('app_directory_sync') }}">{{ 'directorySyncNavLabel'|trans }}</a>
                                        </div>
                                    </div>
                                    <a class="dropdown-item" href="{{ path('app_settings_structure') }}">{{ 'settingsStructureNavLabel'|trans }}</a>
                                </div>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </header>
        <div class="page-wrapper">
            <div class="page-header d-print-none">
                <div class="container-xl">
                    <div class="row g-2 align-items-center">
                        <div class="col">
                            <div class="page-pretitle">{{ 'dashboardPretitle'|trans }}</div>
                            <h2 class="page-title">{% block page_title %}{{ 'homePageHeading'|trans }}{% endblock %}</h2>
                        </div>
                        <div class="col-auto ms-auto">
                            <div class="btn-list">
                                {% block page_actions %}{% endblock %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="page-body">
                <div class="container-xl">
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible" role="alert">
                                {{ message|trans }}
                                <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
                            </div>
                        {% endfor %}
                    {% endfor %}
                    {% block main %}{% endblock %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
