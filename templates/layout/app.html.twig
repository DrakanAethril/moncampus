{% extends 'base.html.twig' %}

{% block body %}
    <div class="page">
        {% set current_route = app.request.attributes.get('_route') %}
        {% set current_program_section_id = structure_nav_current_program_section_id() %}
        <header class="navbar navbar-expand-md d-print-none cm-topbar">
            <div class="container-xl">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-menu" aria-controls="navbar-menu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <h1 class="navbar-brand d-none-navbar-horizontal pe-0 pe-md-3">
                    <a href="{{ path('app_home') }}" class="cm-topbar__brand">
                        <span class="cm-topbar__logo"><img src="{{ asset('images/favicon-32x32.png') }}" alt=""></span>
                        <span class="cm-topbar__name">Institution Beaupeyrat</span>
                    </a>
                </h1>
                <div class="navbar-nav flex-row order-md-last cm-topbar__right">
                    <div class="nav-item d-flex align-items-center"
                         data-controller="theme"
                         data-theme-authenticated-value="true"
                         data-theme-save-url-value="{{ path('app_profile_theme') }}"
                         data-theme-token-value="{{ csrf_token('profile_theme') }}">
                        <button type="button" class="cm-theme-toggle" title="{{ 'toggleThemeLabel'|trans }}" data-action="theme#toggle">
                            <span class="cm-theme-toggle__knob"></span>
                        </button>
                    </div>
                    <div class="nav-item dropdown">
                        {% set navbar_avatar_url = avatar_url(app.user) %}
                        <a href="#" class="nav-link d-flex align-items-center lh-1 text-reset p-0 cm-user__toggle" data-bs-toggle="dropdown" aria-label="{{ 'openUserMenuLabel'|trans }}">
                            <div class="d-none d-xl-block cm-user__id">
                                <div class="cm-user__name">{{ app.user.displayName ?? app.user.username }}</div>
                                <div class="cm-user__login">{{ app.user.username }}</div>
                            </div>
                            <span class="cm-user__avatar"{% if navbar_avatar_url %} style="background-image: url({{ navbar_avatar_url }})"{% endif %}>{% if not navbar_avatar_url %}{{ app.user.initials|default((app.user.displayName ?? app.user.username)|slice(0, 1)|upper) }}{% endif %}</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                            <div class="cm-user__menu-head">
                                <div class="fw-bold" style="color: var(--cm-ink); font-size: 13.5px;">{{ app.user.displayName ?? app.user.username }}</div>
                                {% if app.user.email %}<div style="font-size: 12px; color: var(--cm-faint);">{{ app.user.email }}</div>{% endif %}
                            </div>
                            <a href="{{ path('app_profile') }}" class="dropdown-item">{{ 'profileNavLabel'|trans }}</a>
                            <a href="{{ path('app_logout') }}" class="dropdown-item">{{ 'logoutAction'|trans }}</a>
                        </div>
                    </div>
                </div>
                <div class="collapse navbar-collapse" id="navbar-menu">
                    <ul class="navbar-nav">
                        <li class="nav-item {{ current_route == 'app_home' ? 'active' }}">
                            <a class="nav-link" href="{{ path('app_home') }}">
                                <span class="nav-link-icon d-md-none d-lg-inline-block">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l-2 0l9 -9l9 9l-2 0" /><path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-7" /><path d="M9 21v-6a2 2 0 0 1 2 -2h2a2 2 0 0 1 2 2v6" /></svg>
                                </span>
                                <span class="nav-link-title">{{ 'homeNavLabel'|trans }}</span>
                            </a>
                        </li>
                        {% set unread_message_count = unread_message_thread_count(app.user) %}
                        <li class="nav-item {{ current_route starts with 'app_messages' ? 'active' }}">
                            <a class="nav-link" href="{{ path('app_messages') }}">
                                <span class="nav-link-icon d-md-none d-lg-inline-block">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 5m0 1a1 1 0 0 1 1 -1h16a1 1 0 0 1 1 1v12a1 1 0 0 1 -1 1h-16a1 1 0 0 1 -1 -1z" /><path d="M3 7l9 6l9 -6" /></svg>
                                </span>
                                <span class="nav-link-title">
                                    {{ 'messagesNavLabel'|trans }}
                                    {% if unread_message_count > 0 %}
                                        <span class="badge bg-red text-white ms-1">{{ unread_message_count }}</span>
                                    {% endif %}
                                </span>
                            </a>
                        </li>
                        <li class="nav-item {{ current_route starts with 'app_agenda' ? 'active' }}">
                            <a class="nav-link" href="{{ path('app_agenda') }}">
                                <span class="nav-link-icon d-md-none d-lg-inline-block">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><rect x="4" y="5" width="16" height="16" rx="2" /><path d="M16 3v4M8 3v4M4 11h16" /></svg>
                                </span>
                                <span class="nav-link-title">{{ 'agendaNavLabel'|trans }}</span>
                            </a>
                        </li>
                        {% if is_granted('ROLE_TEACHER') or is_staff() %}
                            <li class="nav-item {{ current_route starts with 'app_library_' ? 'active' }}">
                                <a class="nav-link" href="{{ path('app_library_sequences') }}">
                                    <span class="nav-link-title">{{ 'libraryNavLabel'|trans }}</span>
                                </a>
                            </li>
                        {% endif %}
                        {% for section in structure_nav_sections() %}
                            {% set section_school_year_groups = structure_nav_school_year_groups(section) %}
                            {# Staff see every Section unconditionally (even an empty one); a student/teacher
                               only sees a Section that leads to at least one Program they're actually linked
                               to - structure_nav_school_year_groups() already filters down to those, see
                               App\Security\StructureAccessChecker::isProgramVisible(). #}
                            {% if is_staff() or section_school_year_groups|length > 0 %}
                                <li class="nav-item dropdown {{ current_program_section_id == section.id ? 'active' }}">
                                    <a class="nav-link dropdown-toggle" href="#nav-section-{{ section.id }}" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                        <span class="nav-link-title">{{ section.name }}</span>
                                    </a>
                                    <div class="dropdown-menu">
                                        {% for group in section_school_year_groups %}
                                            <h6 class="dropdown-header">{{ group.schoolYear.startDate|date('Y') }} - {{ group.schoolYear.endDate|date('Y') }}</h6>
                                            {% for program in group.programs %}
                                                <div class="dropend">
                                                    <a class="dropdown-item dropdown-toggle {{ current_route starts with 'app_program_' and app.request.attributes.get('id') == program.id ? 'active' }}" href="#nav-program-{{ program.id }}" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                                        {{ program.shortName }}
                                                    </a>
                                                    <div class="dropdown-menu">
                                                        <a class="dropdown-item {{ current_route == 'app_program_students' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_students', {id: program.id}) }}">{{ 'programStudentsNavLabel'|trans }}</a>
                                                        <a class="dropdown-item {{ current_route == 'app_program_teachers' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_teachers', {id: program.id}) }}">{{ 'programTeachersNavLabel'|trans }}</a>
                                                        {% if program.timetableManagementEnabled %}
                                                            <a class="dropdown-item {{ current_route == 'app_program_timetable' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_timetable', {id: program.id}) }}">{{ 'programTimetableNavLabel'|trans }}</a>
                                                            <a class="dropdown-item {{ current_route == 'app_program_syllabus' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_syllabus', {id: program.id}) }}">{{ 'programSyllabusNavLabel'|trans }}</a>
                                                        {% endif %}
                                                        {% if is_granted('ROLE_ADMIN') %}
                                                            <a class="dropdown-item {{ current_route starts with 'app_program_sequence' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_sequences', {id: program.id}) }}">{{ 'programSequencesNavLabel'|trans }}</a>
                                                        {% endif %}
                                                        {% if is_staff() %}
                                                            {% if program.financialManagementEnabled %}
                                                                <a class="dropdown-item {{ current_route == 'app_program_reporting' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_reporting', {id: program.id}) }}">{{ 'programReportingNavLabel'|trans }}</a>
                                                            {% endif %}
                                                            <a class="dropdown-item {{ current_route starts with 'app_program_exports' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_exports', {id: program.id}) }}">{{ 'programExportsNavLabel'|trans }}</a>
                                                            <div class="dropend">
                                                                <a class="dropdown-item dropdown-toggle {{ (current_route starts with 'app_program_settings' or current_route starts with 'app_program_timetable_settings' or current_route starts with 'app_program_internship') and app.request.attributes.get('id') == program.id ? 'active' }}" href="#nav-program-settings-{{ program.id }}" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                                                    {{ 'programSettingsNavLabel'|trans }}
                                                                </a>
                                                                <div class="dropdown-menu">
                                                                    <a class="dropdown-item {{ current_route starts with 'app_program_settings' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_settings', {id: program.id}) }}">{{ 'programSettingsProgramNavLabel'|trans }}</a>
                                                                    {% if program.timetableManagementEnabled %}
                                                                        <a class="dropdown-item {{ current_route starts with 'app_program_timetable_settings' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_timetable_settings', {id: program.id}) }}">{{ 'programSettingsTimetableTabLabel'|trans }}</a>
                                                                    {% endif %}
                                                                    {% if program.internshipManagementEnabled %}
                                                                        <a class="dropdown-item {{ current_route starts with 'app_program_internship' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_internship', {id: program.id}) }}">{{ 'programInternshipNavLabel'|trans }}</a>
                                                                    {% endif %}
                                                                    {% if program.assignmentManagementEnabled %}
                                                                        <a class="dropdown-item {{ current_route starts with 'app_program_assignments' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_assignments', {id: program.id}) }}">{{ 'programAssignmentsNavLabel'|trans }}</a>
                                                                    {% endif %}
                                                                </div>
                                                            </div>
                                                        {% endif %}
                                                        {% if is_granted('ROLE_STUDENT') and program.internshipManagementEnabled %}
                                                            <a class="dropdown-item {{ current_route starts with 'app_program_internship_my_evaluation' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_internship_my_evaluations', {id: program.id}) }}">{{ 'programInternshipMyEvaluationsNavLabel'|trans }}</a>
                                                        {% endif %}
                                                        {% if is_granted('ROLE_STUDENT') and program.assignmentManagementEnabled %}
                                                            <a class="dropdown-item {{ current_route starts with 'app_program_my_assignment' and app.request.attributes.get('id') == program.id ? 'active' }}" href="{{ path('app_program_my_assignments', {id: program.id}) }}">{{ 'programMyAssignmentsNavLabel'|trans }}</a>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        {% endfor %}
                                    </div>
                                </li>
                            {% endif %}
                        {% endfor %}
                        <li class="nav-item dropdown {{ current_route starts with 'app_tickets' or current_route starts with 'app_laptops' or current_route starts with 'app_directory_' ? 'active' }}">
                            <a class="nav-link dropdown-toggle" href="#navbar-gestion" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                <span class="nav-link-icon d-md-none d-lg-inline-block">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 7m0 2a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2z" /><path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2" /><path d="M12 12l0 .01" /><path d="M3 13a20 20 0 0 0 18 0" /></svg>
                                </span>
                                <span class="nav-link-title">{{ 'gestionNavLabel'|trans }}</span>
                            </a>
                            <div class="dropdown-menu">
                                <div class="dropend">
                                    <a class="dropdown-item dropdown-toggle {{ current_route starts with 'app_tickets' ? 'active' }}" href="#gestion-tickets" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                        {{ 'ticketsGroupNavLabel'|trans }}
                                    </a>
                                    <div class="dropdown-menu">
                                        <a class="dropdown-item {{ current_route starts with 'app_tickets' and current_route != 'app_tickets_queue' and current_route != 'app_tickets_queue_categories' ? 'active' }}" href="{{ path('app_tickets') }}">{{ 'myTicketsNavLabel'|trans }}</a>
                                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') or is_granted('ROLE_STAFF-LEAD') or is_granted('ROLE_SUPPORT-TECH') %}
                                            <a class="dropdown-item {{ current_route == 'app_tickets_queue' or current_route == 'app_tickets_queue_categories' ? 'active' }}" href="{{ path('app_tickets_queue') }}">{{ 'ticketQueueNavLabel'|trans }}</a>
                                        {% endif %}
                                    </div>
                                </div>
                                {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') or is_granted('ROLE_STAFF-LEAD') %}
                                    <div class="dropend">
                                        <a class="dropdown-item dropdown-toggle {{ current_route starts with 'app_laptops' ? 'active' }}" href="#gestion-loan" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                            {{ 'loanGroupNavLabel'|trans }}
                                        </a>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item {{ current_route starts with 'app_laptops' ? 'active' }}" href="{{ path('app_laptops') }}">{{ 'laptopsNavLabel'|trans }}</a>
                                        </div>
                                    </div>
                                    <div class="dropend">
                                        <a class="dropdown-item dropdown-toggle {{ current_route starts with 'app_directory_' ? 'active' }}" href="#gestion-directory" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                            {{ 'directoryNavLabel'|trans }}
                                        </a>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item" href="{{ path('app_directory_groups') }}">{{ 'directoryGroupsNavLabel'|trans }}</a>
                                            <a class="dropdown-item" href="{{ path('app_directory_users') }}">{{ 'directoryUsersNavLabel'|trans }}</a>
                                            <a class="dropdown-item" href="{{ path('app_directory_passwords') }}">{{ 'directoryPasswordsNavLabel'|trans }}</a>
                                            {# Admin-only, stricter than the rest of this dropend (staff/staff-lead too) - see
                                               DirectoryServiceController/DirectoryComputerController. #}
                                            {% if is_granted('ROLE_ADMIN') %}
                                                <a class="dropdown-item" href="{{ path('app_directory_services') }}">{{ 'directoryServicesNavLabel'|trans }}</a>
                                                <a class="dropdown-item" href="{{ path('app_directory_computers') }}">{{ 'directoryComputersNavLabel'|trans }}</a>
                                            {% endif %}
                                        </div>
                                    </div>
                                    {# Deliberately a flat link, not nested under Directory - separate concern (local-only
                                       profile fields/group assignment, no LDAP queue involved at all), see UserManagementController. #}
                                    <a class="dropdown-item {{ current_route starts with 'app_users' ? 'active' }}" href="{{ path('app_users') }}">{{ 'usersNavLabel'|trans }}</a>
                                {% endif %}
                            </div>
                        </li>
                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') or is_granted('ROLE_STAFF-LEAD') %}
                            <li class="nav-item dropdown {{ current_route starts with 'app_settings_' ? 'active' }}">
                                <a class="nav-link dropdown-toggle" href="#navbar-settings" data-bs-toggle="dropdown" data-bs-auto-close="outside" role="button" aria-expanded="false">
                                    <span class="nav-link-icon d-md-none d-lg-inline-block">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.572 1.065c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.065 -2.572c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37c1 .608 2.296 .07 2.572 -1.065z" /><path d="M9 12a3 3 0 1 0 6 0a3 3 0 0 0 -6 0" /></svg>
                                    </span>
                                    <span class="nav-link-title">{{ 'settingsNavLabel'|trans }}</span>
                                </a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item {{ current_route in ['app_settings_structure_sections', 'app_settings_structure_tracks', 'app_settings_structure_cohorts', 'app_settings_structure_rooms', 'app_settings_structure_options', 'app_settings_structure_modalities', 'app_settings_structure_lesson_types', 'app_settings_structure_skill_levels'] ? 'active' }}" href="{{ path('app_settings_configuration') }}">{{ 'settingsConfigurationNavLabel'|trans }}</a>
                                    <a class="dropdown-item {{ current_route in ['app_settings_structure_school_years', 'app_settings_structure_programs', 'app_settings_structure_periods'] ? 'active' }}" href="{{ path('app_settings_pedagogique') }}">{{ 'settingsPedagogiqueNavLabel'|trans }}</a>
                                    <a class="dropdown-item {{ current_route starts with 'app_settings_ufa' ? 'active' }}" href="{{ path('app_settings_ufa_configuration') }}">{{ 'settingsUfaNavLabel'|trans }}</a>
                                    <a class="dropdown-item" href="{{ path('app_settings_internship') }}">{{ 'settingsInternshipNavLabel'|trans }}</a>
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <a class="dropdown-item {{ current_route starts with 'app_settings_groups' ? 'active' }}" href="{{ path('app_settings_groups') }}">{{ 'settingsGroupsNavLabel'|trans }}</a>
                                    {% endif %}
                                </div>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </header>
        <div class="page-wrapper">
            <div class="page-header d-print-none">
                <div class="container-xl">
                    <div class="row g-2 align-items-center">
                        <div class="col">
                            <div class="page-pretitle">{{ 'dashboardPretitle'|trans }}</div>
                            <h2 class="page-title">{% block page_title %}{{ 'homePageHeading'|trans }}{% endblock %}</h2>
                        </div>
                        <div class="col-auto ms-auto">
                            <div class="btn-list">
                                {% block page_actions %}{% endblock %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="page-body">
                <div class="container-xl">
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible" role="alert">
                                {{ message|trans }}
                                <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
                            </div>
                        {% endfor %}
                    {% endfor %}
                    {% block main %}{% endblock %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
