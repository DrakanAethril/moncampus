# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL=mysql://${MYSQL_USER:-user_beaupeyrat}:${MYSQL_PASSWORD:-password}@database:3306/${MYSQL_DATABASE:-beaupeyrat_mgmt}?serverVersion=${MYSQL_VERSION:-8.0.32}&charset=${MYSQL_CHARSET:-utf8mb4}
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> symfony/ldap ###
# Defaults match the dev-only `openldap` container in compose.override.yaml.
# Point these at the real corporate LDAP server in prod (via .env.local.php / secrets).
LDAP_HOST=openldap
LDAP_PORT=1389
LDAP_BASE_DN="dc=beaupeyrat,dc=lan"
# Dedicated read-only bind account (not the directory rootDN) - see frankenphp/ldap/examples/10-tree.example.ldif
LDAP_SEARCH_DN="cn=svc-app,ou=service,dc=beaupeyrat,dc=lan"
LDAP_SEARCH_PASSWORD=password
###< symfony/ldap ###

###> league/flysystem-aws-s3-v3 ###
# S3-compatible storage for uploaded files (avatars/ first, more feature prefixes later - see
# App\Service\FileUploadService, App\Service\S3ClientFactory). Defaults match the dev-only
# `minio` container in compose.override.yaml. AWS_S3_ENDPOINT must stay empty in production
# (real AWS) - see compose.prod.yaml, which overrides every var in this block.
AWS_S3_BUCKET=moncampus-dev
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# Only used as a fallback when AWS_CLOUDFRONT_DOMAIN is blank (see below): AWS_S3_ENDPOINT above
# is the *internal* Docker-network address PHP uses for S3 API calls (server-to-server), which a
# browser on the host can't reach - this is the browser-facing equivalent for viewing an uploaded
# file directly from MinIO without a CloudFront distribution in front of it.
AWS_S3_PUBLIC_ENDPOINT=http://localhost:9000
# CloudFront distribution domain fronting the bucket (a real, non-secret value once a dev
# distribution exists - different per environment, see compose.prod.yaml for production).
# FileUploadService falls back to AWS_S3_PUBLIC_ENDPOINT when this is blank.
AWS_CLOUDFRONT_DOMAIN=
###< league/flysystem-aws-s3-v3 ###
