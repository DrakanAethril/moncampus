# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

TRUSTED_PROXIES=

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
#
# Non-functional placeholder - real environment variables always win over this at runtime (see
# this file's own header comment), so this is only ever actually used by the prod Docker build's
# `composer run-script post-install-cmd` -> `cache:clear` step, which needs SOME resolvable
# DATABASE_URL to compile the container even though .env.prod.local (with the real value) is
# deliberately excluded from the build context via .dockerignore. The real DATABASE_URL (and
# MYSQL_ROOT_PASSWORD/MYSQL_USER/MYSQL_PASSWORD/MYSQL_DATABASE for the `database` container's own
# bootstrap) is credential-shaped and lives in .env.dev.local for dev (see .env.dev.local.example),
# and as a required real env var in production - see compose.prod.yaml and docs/production.md.
DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> symfony/ldap ###
# Real values (host/port/base DN/bind DN/bind password) are credential-shaped and live in
# .env.dev.local for dev (see .env.dev.local.example), and as required real env vars in
# production - see compose.prod.yaml and docs/production.md.
#
# Placeholders below exist only so the prod Docker build's cache:clear step can compile the
# container (it eagerly constructs the LDAP adapter/S3 client, see DATABASE_URL's fuller
# explanation above) - real environment variables always override these at runtime.
# LDAP_ENCRYPTION must be one of none/ssl/tls (App\Service\LdapAdapterFactory validates it eagerly).
LDAP_HOST=
LDAP_PORT=389
LDAP_BASE_DN=
# Optional - scopes the Directory > Users bulk sync (App\Service\LdapUserSyncer). On a Samba 4 AD
# DC, leaving this blank (falling back to LDAP_BASE_DN) means the sync also matches computer/
# service accounts, since those are objectClass=user entries too - set this to wherever real
# people live (e.g. OU=People) to avoid that. Login itself is unaffected either way.
LDAP_USER_BASE_DN=
# Optional - only needed when groups live under a different subtree than LDAP_BASE_DN (e.g. a
# Samba 4 AD DC with users under OU=People and groups under OU=Groups). Leave blank to search
# groups under LDAP_BASE_DN itself, same as dev's single-OU tree.
LDAP_GROUP_BASE_DN=
# Same idea as LDAP_GROUP_BASE_DN, for the Directory > Services/Computers pages - e.g. a Samba 4
# AD DC's OU=Services / CN=Computers containers. Blank falls back to LDAP_BASE_DN.
LDAP_SERVICE_BASE_DN=
LDAP_COMPUTER_BASE_DN=
LDAP_SEARCH_DN=
LDAP_SEARCH_PASSWORD=
LDAP_ENCRYPTION=none
LDAP_TLS_CA_CERT_PATH=
LDAP_USERNAME_ATTRIBUTE=
LDAP_USER_OBJECT_CLASS=
LDAP_GROUP_OBJECT_CLASS=
###< symfony/ldap ###

###> league/flysystem-aws-s3-v3 ###
# S3-compatible storage for uploaded files (avatars/ first, more feature prefixes later - see
# App\Service\FileUploadService, App\Service\S3ClientFactory). Real values are credential-shaped
# and live in .env.dev.local for dev (see .env.dev.local.example), and as required real env vars
# in production - see compose.prod.yaml and docs/production.md.
#
# Placeholders below exist only so the prod Docker build's cache:clear step can compile the
# container - see DATABASE_URL's fuller explanation above. AWS_S3_REGION must be non-blank (the
# AWS SDK validates it eagerly at client construction); the rest can stay blank.
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_ENDPOINT=
AWS_S3_PREFIX=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CLOUDFRONT_DOMAIN=
###< league/flysystem-aws-s3-v3 ###

###> app/gotenberg ###
# Placeholder for the same reason as above - real value comes from compose.yaml (not a secret,
# see that file's comment on GOTENBERG_URL).
GOTENBERG_URL=
###< app/gotenberg ###
