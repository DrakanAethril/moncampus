dn: uid=jdupont,ou=users,dc=beaupeyrat,dc=lan
objectClass: inetOrgPerson
cn: Jean Dupont
sn: Dupont
givenName: Jean
uid: jdupont
mail: jdupont@beaupeyrat.lan
userPassword: password

