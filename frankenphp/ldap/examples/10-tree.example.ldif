# EXAMPLE seed data - fictitious people, safe to commit.
# Copy this file to ../10-tree.local.ldif (or any *.ldif directly under frankenphp/ldap/)
# and replace with real data; that filename is gitignored.

# Base tree
dn: dc=beaupeyrat,dc=lan
objectClass: dcObject
objectClass: organization
dc: beaupeyrat
o: beaupeyrat

dn: ou=users,dc=beaupeyrat,dc=lan
objectClass: organizationalUnit
ou: users

dn: ou=groups,dc=beaupeyrat,dc=lan
objectClass: organizationalUnit
ou: groups

dn: ou=service,dc=beaupeyrat,dc=lan
objectClass: organizationalUnit
ou: service

# Service account used by the app to bind/search the directory (read-only: no write ACL granted)
dn: cn=svc-app,ou=service,dc=beaupeyrat,dc=lan
objectClass: organizationalRole
objectClass: simpleSecurityObject
cn: svc-app
description: Symfony app LDAP bind account (LDAP_SEARCH_DN) - read-only
userPassword: password

# admin account (app login, member of the admin group -> ROLE_ADMIN)
dn: uid=admin,ou=users,dc=beaupeyrat,dc=lan
objectClass: inetOrgPerson
cn: admin
sn: admin
uid: admin
mail: admin@beaupeyrat.lan
userPassword: password

