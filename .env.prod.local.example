# Template for .env.prod.local (gitignored, never committed - see .gitignore's /.env.*.local
# pattern, and .dockerignore, which keeps it out of the built image entirely). Create this file
# directly on the production server, in the same directory as compose.yaml:
#
#   cp .env.prod.local.example .env.prod.local
#
# then fill in every value below with real production secrets before running
# `docker compose -f compose.yaml -f compose.prod.yaml up --wait` - see docs/production.md.
# compose.prod.yaml's `env_file: - .env.prod.local` on the php service is what reads this file
# (Docker Compose's own ${} substitution can't read it directly - see compose.yaml's comments on
# why these vars are never defaulted there). SERVER_NAME and APP_SECRET are passed separately, as
# real inline env vars on the deploy command itself - see docs/production.md.

###> doctrine/doctrine-bundle ###
# Point this at your real production database. This app's own containerized MySQL (compose.yaml's
# `database` service) only runs in dev (compose.override.yaml) - production is expected to use an
# external/managed database.
DATABASE_URL=mysql://user:password@host:3306/database?serverVersion=8.0.32&charset=utf8mb4
###< doctrine/doctrine-bundle ###

###> symfony/mercure-bundle ###
# Also read directly by Caddy's Mercure module (not just PHP) - all three should be the same
# cryptographically secure random value.
MERCURE_PUBLISHER_JWT_KEY=
MERCURE_SUBSCRIBER_JWT_KEY=
MERCURE_JWT_SECRET=
###< symfony/mercure-bundle ###

###> symfony/ldap ###
# Point these at the real corporate LDAP server - see App\Security\LdapAuthenticator.
LDAP_HOST=
LDAP_PORT=389
LDAP_BASE_DN=
LDAP_SEARCH_DN=
LDAP_SEARCH_PASSWORD=
###< symfony/ldap ###

###> league/flysystem-aws-s3-v3 ###
AWS_S3_BUCKET=
# Optional - scopes this environment within the bucket if it's shared with other environments
# (e.g. "prod/"), blank if production owns the bucket root - see config/packages/flysystem.yaml.
AWS_S3_PREFIX=
AWS_S3_REGION=
# Must stay blank in production (real AWS resolves its own endpoint from AWS_S3_REGION) - a
# non-empty value is only ever correct for local MinIO dev - see App\Service\S3ClientFactory.
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CLOUDFRONT_DOMAIN=
###< league/flysystem-aws-s3-v3 ###
