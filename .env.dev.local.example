# Template for .env.dev.local (gitignored, never committed - see .gitignore's /.env.*.local
# pattern). Copy this file to .env.dev.local and fill in the blank values before running
# `docker compose up` for the first time:
#
#   cp .env.dev.local.example .env.dev.local
#
# Hostnames/ports below are safe to keep as-is (they just point at the dev-only containers in
# compose.override.yaml); the blank values are real credentials you need to set yourself. None of
# this needs to be a "strong" password - everything here is local-only, throwaway infrastructure,
# not real production systems - but it still shouldn't be committed, since a fresh clone
# shouldn't ship with working default credentials baked into git history.

###> doctrine/doctrine-bundle ###
MYSQL_ROOT_PASSWORD=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=beaupeyrat_mgmt
# Must match MYSQL_USER/MYSQL_PASSWORD/MYSQL_DATABASE above.
DATABASE_URL=mysql://<MYSQL_USER>:<MYSQL_PASSWORD>@database:3306/<MYSQL_DATABASE>?serverVersion=8.0.32&charset=utf8mb4
###< doctrine/doctrine-bundle ###

###> symfony/mercure-bundle ###
MERCURE_PUBLISHER_JWT_KEY=
MERCURE_SUBSCRIBER_JWT_KEY=
MERCURE_JWT_SECRET=
###< symfony/mercure-bundle ###

###> symfony/ldap ###
LDAP_HOST=openldap
LDAP_PORT=1389
LDAP_BASE_DN="dc=beaupeyrat,dc=lan"
LDAP_SEARCH_DN="cn=svc-app,ou=service,dc=beaupeyrat,dc=lan"
LDAP_SEARCH_PASSWORD=
LDAP_ADMIN_PASSWORD=
# Dev's openldap container speaks plain LDAP (no TLS) - production connects over LDAPS instead
# and verifies the server's certificate, see App\Service\LdapAdapterFactory and docs/production.md.
LDAP_ENCRYPTION=none
LDAP_TLS_CA_CERT_PATH=
# Dev's openldap container is classic OpenLDAP/RFC2307 schema - production is a Samba 4 AD DC
# (user/sAMAccountName/group), see App\Security\LdapAuthenticator, App\Security\LdapUserMapper,
# App\Service\LdapUserSyncer, and docs/production.md.
LDAP_USERNAME_ATTRIBUTE=uid
LDAP_USER_OBJECT_CLASS=inetOrgPerson
LDAP_GROUP_OBJECT_CLASS=groupOfNames
###< symfony/ldap ###

###> app/ldap-password-queue ###
AES_KEY=
###< app/ldap-password-queue ###

###> symfony/mailer ###
# The "mailer" compose service is Mailpit (compose.override.yaml) - it accepts any SMTP mail
# without actually delivering it, viewable at http://localhost:<mapped 8025 port>
# (`docker compose port mailer 8025`). No credentials needed.
MAILER_DSN=smtp://mailer:1025
###< symfony/mailer ###

###> symfony/discord-notifier ###
# Unlike Mailpit for email, there's no fake/local Discord to point dev at - this posts to a real
# channel. Safe to point at the same webhook as production: every message sent while
# kernel.environment != 'prod' is automatically prefixed with "[DEV] " (see
# App\Service\TicketDiscordNotifier), so dev/prod messages stay distinguishable in the same
# channel even without separate webhooks.
#
# Discord gives you a webhook URL shaped like
# https://discord.com/api/webhooks/<DISCORD_WEBHOOK_ID>/<DISCORD_WEBHOOK_TOKEN> when you create
# one (channel settings > Integrations > Webhooks > New Webhook) - split it into the two values
# below rather than pasting the whole URL as one DSN (see config/packages/notifier.yaml for why).
#
# Keep these non-blank even before you've set up a real webhook - unlike every other credential
# placeholder in this file, Symfony Notifier parses this DSN as soon as ChatterInterface is first
# injected anywhere (not lazily on first send() like the AWS/LDAP clients), so an empty
# webhook_id/token 500s any page that injects App\Service\TicketDiscordNotifier.
DISCORD_WEBHOOK_TOKEN=unconfigured
DISCORD_WEBHOOK_ID=0
###< symfony/discord-notifier ###

###> league/flysystem-aws-s3-v3 ###
# Defaults below point at the dev-only MinIO container (compose.override.yaml) - the simplest
# option for local dev. To use a real AWS S3 bucket instead (e.g. shared with production under a
# "dev/" prefix), set AWS_S3_ENDPOINT blank, AWS_S3_BUCKET/AWS_S3_REGION to the real bucket, and
# AWS_S3_PREFIX to scope this environment - see config/packages/flysystem.yaml.
AWS_S3_BUCKET=moncampus-dev
AWS_S3_PREFIX=
AWS_S3_REGION=us-east-1
AWS_S3_ENDPOINT=http://minio:9000
AWS_S3_PUBLIC_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_CLOUDFRONT_DOMAIN=
# Must match AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY above.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
###< league/flysystem-aws-s3-v3 ###
